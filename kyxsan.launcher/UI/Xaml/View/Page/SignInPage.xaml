<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.SignInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <!--  Not logged in state  -->
        <Border
            x:Name="NotLoggedInPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
            Visibility="Collapsed">
            <Border
                MinWidth="480"
                Padding="16"
                Style="{ThemeResource AcrylicBorderCardStyle}">
                <StackPanel>
                    <Image
                        MaxWidth="120"
                        MaxHeight="120"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Source="ms-appx:///Resource/Icon/kyxsan01.png"/>
                    <TextBlock
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{shuxm:ResourceString Name=ViewCommonLoginRequiredHint}"/>
                    <StackPanel Margin="0,0,0,0" Spacing="{StaticResource SettingsCardSpacing}">
                        <cwcont:SettingsCard
                            x:Name="LoginByQRCodeCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginQRCodeDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginQRCodeHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xED14;}"
                            IsClickEnabled="True"/>
                        <cwcont:SettingsCard
                            x:Name="LoginByMobileCaptchaCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE8EA;}"
                            IsClickEnabled="True"/>
                        <cwcont:SettingsCard
                            x:Name="ManualInputCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginManualInputDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginManualInputHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE109;}"
                            IsClickEnabled="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!--  Logged in state  -->
        <ScrollViewer
            x:Name="LoggedInPanel"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            Padding="24"
            Visibility="Collapsed">
            <cwcont:UniformGrid
                x:Name="SignInCardsGrid"
                Columns="2"
                ColumnSpacing="16"
                RowSpacing="16"/>
        </ScrollViewer>
    </Grid>
</shuxc:ScopedPage>
