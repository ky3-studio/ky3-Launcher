<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwconv="using:CommunityToolkit.WinUI.Converters"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shvi="using:kyxsan.ViewModel.Inventory"
    xmlns:si="using:kyxsan.Service.Inventory"
    d:DataContext="{d:DesignInstance shvi:InventoryViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <cwconv:BoolToObjectConverter x:Key="BoolToVisibilityConverter" TrueValue="Visible" FalseValue="Collapsed"/>
        <cwconv:BoolToObjectConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Border Background="#40000000"/>
        <shuxc:StandardView ShowCondition="{Binding HasWeapons}">
            <shuxc:StandardView.EmptyContent>
                <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border
                        MinWidth="480"
                        Padding="24"
                        Style="{ThemeResource AcrylicBorderCardStyle}">
                        <StackPanel Spacing="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="48"
                                Glyph="&#xE945;"/>
                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewInventoryEmptyHint}"/>
                            <StackPanel Margin="0,16,0,0" Spacing="{StaticResource SettingsCardSpacing}">
                                <cwcont:SettingsCard
                                    Command="{Binding StartCaptureCommand}"
                                    Description="{shuxm:ResourceString Name=ViewInventoryCaptureDescription}"
                                    Header="{shuxm:ResourceString Name=ViewInventoryInjectButton}"
                                    HeaderIcon="{shuxm:FontIcon Glyph=&#xE768;}"
                                    IsClickEnabled="True"/>
                            </StackPanel>
                            <StackPanel
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <ProgressRing
                                    Width="16"
                                    Height="16"
                                    IsActive="{Binding IsLoading}"
                                    Visibility="{Binding IsLoading}"/>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{Binding StatusText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </shuxc:StandardView.EmptyContent>

            <Grid Margin="16">
                <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid>
                            <Grid Visibility="{Binding ShowDetail, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="16,12,16,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{shuxm:ResourceString Name=ViewInventoryTotalCount}"/>
                                            <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{Binding TotalWeaponCount}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{shuxm:ResourceString Name=ViewInventoryTypeCount}"/>
                                            <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{Binding WeaponTypeCount}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <ProgressRing
                                        Grid.Column="1"
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,8,0"
                                        IsActive="{Binding IsLoading}"
                                        Visibility="{Binding IsLoading}"/>
                                    <TextBlock
                                        Grid.Column="2"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding StatusText}"/>
                                    <Button
                                        Grid.Column="3"
                                        Command="{Binding StartCaptureCommand}"
                                        Content="{shuxm:ResourceString Name=ViewInventoryRefreshButton}"
                                        Style="{ThemeResource AccentButtonStyle}"/>
                                </Grid>

                                <ScrollViewer Grid.Row="1" Padding="16,0,16,16">
                                    <StackPanel Spacing="16">
                                        <StackPanel Spacing="8" Visibility="{Binding FiveStarWeapons.Count, Converter={StaticResource Int32ToVisibilityConverter}}">
                                            <TextBlock FontWeight="Bold" Foreground="#FFB13E" Text="&#x4E94;&#x661F;"/>
                                            <ItemsRepeater ItemsSource="{Binding FiveStarWeapons}">
                                                <ItemsRepeater.Layout>
                                                    <UniformGridLayout ItemsStretch="None" MinColumnSpacing="8" MinItemHeight="120" MinItemWidth="96" MinRowSpacing="8"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="si:WeaponEntry">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectWeaponCommand, ElementName=RootGrid}"
                                                            CommandParameter="{x:Bind}"
                                                            CornerRadius="6">
                                                            <Grid Width="96" Height="120" Background="#55FFB13E" CornerRadius="6">
                                                                <TextBlock Margin="6,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Type}"/>
                                                                <Border Margin="0,4,6,0" Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#80000000" CornerRadius="4">
                                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" Text="{x:Bind Refinement}"/>
                                                                </Border>
                                                                <StackPanel Margin="6,0,6,8" VerticalAlignment="Bottom">
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold" MaxLines="1" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind LevelText}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>

                                        <StackPanel Spacing="8" Visibility="{Binding FourStarWeapons.Count, Converter={StaticResource Int32ToVisibilityConverter}}">
                                            <TextBlock FontWeight="Bold" Foreground="#D28FD6" Text="&#x56DB;&#x661F;"/>
                                            <ItemsRepeater ItemsSource="{Binding FourStarWeapons}">
                                                <ItemsRepeater.Layout>
                                                    <UniformGridLayout ItemsStretch="None" MinColumnSpacing="8" MinItemHeight="120" MinItemWidth="96" MinRowSpacing="8"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="si:WeaponEntry">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectWeaponCommand, ElementName=RootGrid}"
                                                            CommandParameter="{x:Bind}"
                                                            CornerRadius="6">
                                                            <Grid Width="96" Height="120" Background="#55D28FD6" CornerRadius="6">
                                                                <TextBlock Margin="6,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Type}"/>
                                                                <Border Margin="0,4,6,0" Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#80000000" CornerRadius="4">
                                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" Text="{x:Bind Refinement}"/>
                                                                </Border>
                                                                <StackPanel Margin="6,0,6,8" VerticalAlignment="Bottom">
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold" MaxLines="1" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind LevelText}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>

                                        <StackPanel Spacing="8" Visibility="{Binding ThreeStarWeapons.Count, Converter={StaticResource Int32ToVisibilityConverter}}">
                                            <TextBlock FontWeight="Bold" Foreground="#72A8D2" Text="&#x4E09;&#x661F;"/>
                                            <ItemsRepeater ItemsSource="{Binding ThreeStarWeapons}">
                                                <ItemsRepeater.Layout>
                                                    <UniformGridLayout ItemsStretch="None" MinColumnSpacing="8" MinItemHeight="120" MinItemWidth="96" MinRowSpacing="8"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="si:WeaponEntry">
                                                        <Button
                                                            Padding="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectWeaponCommand, ElementName=RootGrid}"
                                                            CommandParameter="{x:Bind}"
                                                            CornerRadius="6">
                                                            <Grid Width="96" Height="120" Background="#5572A8D2" CornerRadius="6">
                                                                <TextBlock Margin="6,4,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Type}"/>
                                                                <Border Margin="0,4,6,0" Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#80000000" CornerRadius="4">
                                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" Text="{x:Bind Refinement}"/>
                                                                </Border>
                                                                <StackPanel Margin="6,0,6,8" VerticalAlignment="Bottom">
                                                                    <TextBlock FontSize="12" FontWeight="SemiBold" MaxLines="1" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind LevelText}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <Grid Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="16,12,16,8">
                                    <Button Command="{Binding BackToListCommand}" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE72B;"/>
                                            <TextBlock Text="&#x8FD4;&#x56DE;&#x5217;&#x8868;"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1" Padding="16,0,16,16">
                                    <StackPanel MaxWidth="600" HorizontalAlignment="Left" Spacing="16">
                                        <Grid Style="{ThemeResource GridShimmerStyle}">
                                            <StackPanel Margin="20" Spacing="8">
                                                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{Binding SelectedWeapon.Name}"/>
                                                <TextBlock FontSize="18" Foreground="#FFD700" Text="{Binding SelectedWeapon.Stars}"/>
                                                <cwcont:UniformGrid Margin="0,12,0,0" ColumnSpacing="6" Columns="4">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewInventoryWeaponType}"/>
                                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding SelectedWeapon.Type}"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewInventoryWeaponLevel}"/>
                                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding SelectedWeapon.LevelText}"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewInventoryWeaponPromote}"/>
                                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding SelectedWeapon.PromoteText}"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewInventoryWeaponRefinement}"/>
                                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource CaptionTextBlockStyle}" Text="{Binding SelectedWeapon.RefinementText}"/>
                                                    </StackPanel>
                                                </cwcont:UniformGrid>
                                            </StackPanel>
                                        </Grid>

                                        <Border Padding="20" Style="{ThemeResource BorderShimmerStyle}" Visibility="{Binding SelectedWeapon.AffixName, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                            <StackPanel Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Style="{StaticResource BaseTextBlockStyle}" Text="{Binding SelectedWeapon.AffixName}"/>
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding SelectedWeapon.AffixDescription}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Padding="20" Style="{ThemeResource BorderShimmerStyle}" Visibility="{Binding SelectedWeapon.Description, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="&#x6B66;&#x5668;&#x63CF;&#x8FF0;"/>
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding SelectedWeapon.Description}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </shuxc:StandardView>
    </Grid>
</shuxc:ScopedPage>
