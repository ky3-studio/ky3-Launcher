            <PivotItem Header="{shuxm:ResourceString Name=ViewPageLaunchGameCustomDllHeader}">
                <Border
                    Margin="16"
                    Padding="0"
                    cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Grid Style="{ThemeResource AcrylicGridCardStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        
                        <!-- 警告提示 -->
                        <Border
                            Grid.Row="0"
                            Background="{ThemeResource InfoBarWarningSeverityBackgroundBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <TextBlock
                                Margin="6"
                                HorizontalAlignment="Center"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewPageLaunchGameCustomDllWarning}"/>
                        </Border>
                        
                        <!-- DLL 列表 -->
                        <ScrollViewer Grid.Row="1" Padding="16">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock 
                                        Text="{shuxm:ResourceString Name=ViewPageLaunchGameCustomDllListHeader}" 
                                        FontWeight="SemiBold" 
                                        Foreground="{ThemeResource SystemAccentColor}"
                                        VerticalAlignment="Center"/>
                                    <Button 
                                        Grid.Column="1"
                                        Content="{shuxm:ResourceString Name=ViewPageLaunchGameCustomDllAdd}"
                                        Command="{Binding AddCustomDllCommand}"/>
                                </Grid>
                                
                                <!-- DLL 列表 -->
                                <ItemsControl ItemsSource="{Binding LaunchOptions.CustomDllConfigs.Value}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border 
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                                CornerRadius="4" 
                                                Padding="12,8"
                                                Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition Width="auto"/>
                                                        <ColumnDefinition Width="auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock 
                                                        Text="{Binding Key}" 
                                                        VerticalAlignment="Center"
                                                        TextTrimming="CharacterEllipsis"
                                                        ToolTipService.ToolTip="{Binding Key}"/>
                                                    <Button 
                                                        Grid.Column="1"
                                                        Margin="8,0"
                                                        Content="{shuxm:ResourceString Name=ViewPageLaunchGameCustomDllRemove}"
                                                        Command="{Binding DataContext.RemoveCustomDllCommand, ElementName=PageRoot}"
                                                        CommandParameter="{Binding Key}"/>
                                                    <ToggleSwitch
                                                        Grid.Column="2"
                                                        MinWidth="50"
                                                        VerticalAlignment="Center"
                                                        IsOn="{Binding Value, Mode=OneWay}"
                                                        Toggled="OnCustomDllToggled"
                                                        Tag="{Binding Key}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
