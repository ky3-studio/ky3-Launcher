<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.LaunchGamePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shas="using:kyxsan.Service.Game.AdvancedStart.Model"
    xmlns:shme="using:kyxsan.Model.Entity"
    xmlns:shsg="using:kyxsan.Service.Game"
    xmlns:shsgp="using:kyxsan.Service.Game.PathAbstraction"
    xmlns:shux="using:kyxsan.UI.Xaml"
    xmlns:shwt="using:kyxsan.Web.ThirdPartyTool"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxba="using:kyxsan.UI.Xaml.Behavior.Action"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxcc="using:kyxsan.UI.Xaml.Control.Card"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxconv="using:kyxsan.UI.Xaml.Data.Converter"
    xmlns:shuxdcs="using:kyxsan.UI.Xaml.Data.Converter.Specialized"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shvg="using:kyxsan.ViewModel.Game"
    xmlns:shvu="using:kyxsan.ViewModel.User"
    d:DataContext="{d:DesignInstance shvg:LaunchGameViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <shux:BindingProxy x:Key="BindingProxy" DataContext="{Binding}"/>
        <shuxconv:DelayToIndexConverter x:Key="DelayToIndexConverter"/>
        <shuxconv:FilePathToDisplayNameConverter x:Key="FilePathToDisplayNameConverter"/>
        <shuxdcs:UriToHighResBitmapConverter x:Key="UriToHighResBitmapConverter"/>

        <DataTemplate x:Key="GameAccountListTemplate" x:DataType="shme:GameAccount">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Margin="0,16"
                    VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{Binding Name}"/>
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchAccountExpired}"
                        Visibility="{Binding IsExpired, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel
                    x:Name="ButtonPanel"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <!--  ReSharper disable once Xaml.BindingWithContextNotResolved  -->
                    <Button
                        MinWidth="35.2"
                        Margin="4,8"
                        VerticalAlignment="Stretch"
                        Command="{Binding DataContext.ModifyGameAccountCommand, Source={StaticResource BindingProxy}}"
                        CommandParameter="{Binding}"
                        Content="&#xE8AC;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchAccountRenameToolTip}"/>
                    <!--  ReSharper disable once Xaml.BindingWithContextNotResolved  -->
                    <Button
                        MinWidth="35.2"
                        Margin="4,8,0,8"
                        VerticalAlignment="Stretch"
                        Command="{Binding DataContext.RemoveGameAccountCommand, Source={StaticResource BindingProxy}}"
                        CommandParameter="{Binding}"
                        Content="&#xE74D;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchAccountRemoveToolTip}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GamePathEntryListTemplate" x:DataType="shsgp:GamePathEntry">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Padding="0,16"
                    VerticalAlignment="Center"
                    Text="{Binding Path}"/>
                <!--  ReSharper disable once Xaml.BindingWithContextNotResolved  -->
                <Button
                    Grid.Column="1"
                    MinWidth="48"
                    Margin="4,8,0,8"
                    VerticalAlignment="Stretch"
                    Command="{Binding DataContext.RemoveGamePathEntryCommand, Source={StaticResource BindingProxy}}"
                    CommandParameter="{Binding}"
                    Content="&#xE74D;"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchAccountRemoveToolTip}"/>
            </Grid>
        </DataTemplate>

        <shvg:AspectRatioComboBoxTemplateSelector x:Key="AspectRatioComboBoxTemplateSelector">
            <shvg:AspectRatioComboBoxTemplateSelector.ListTemplate>
                <DataTemplate x:DataType="shsg:AspectRatio">
                    <!--  ComboBoxItemThemePadding 11,5,11,7  -->
                    <Grid Margin="1,-1,-7,-3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" Text="{Binding}"/>
                        <!--  ReSharper disable once Xaml.BindingWithContextNotResolved  -->
                        <Button
                            Grid.Column="1"
                            MinWidth="32"
                            MinHeight="32"
                            Padding="0"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.RemoveAspectRatioCommand, Source={StaticResource BindingProxy}}"
                            CommandParameter="{Binding}"
                            Content="&#xE711;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Style="{ThemeResource SettingButtonStyle}"/>
                    </Grid>
                </DataTemplate>
            </shvg:AspectRatioComboBoxTemplateSelector.ListTemplate>
        </shvg:AspectRatioComboBoxTemplateSelector>
    </Page.Resources>

    <Grid>
        <Border Background="#40000000"/>
        <shuxc:StandardView ShowCondition="{Binding GamePathEntryValid.Value, Mode=OneWay}" Style="{ThemeResource DefaultStandardViewStyle}">
        <shuxc:StandardView.EmptyContent>
            <Border
                Margin="128,0"
                Padding="16"
                VerticalAlignment="Center"
                Style="{ThemeResource AcrylicBorderCardStyle}">
                <StackPanel
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Spacing="3">
                    <Image
                        MaxWidth="120"
                        MaxHeight="120"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Source="ms-appx:///Resource/Icon/kyxsan08.png"/>
                    <TextBlock
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{shuxm:ResourceString Name=ViewPageLaunchGameSelectGamePath}"/>
                    <TextBlock
                        Margin="0,5,0,21"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource SystemErrorTextColor}"
                        Text="{shuxm:ResourceString Name=ViewPageLaunchGameSelectGamePathHint}"/>
                    <Border Style="{ThemeResource BorderCardStyle}" Visibility="{Binding LaunchOptions.GamePathEntries.Value.Length, Converter={StaticResource Int32ToVisibilityConverter}}">
                        <ListView
                            ItemTemplate="{StaticResource GamePathEntryListTemplate}"
                            ItemsSource="{Binding LaunchOptions.GamePathEntries.Value}"
                            SelectedItem="{Binding GamePathEntry.Value, Mode=TwoWay}"/>
                    </Border>
                    <cwc:SettingsCard
                        ActionIcon="{shuxm:FontIcon Glyph=&#xE76C;}"
                        ActionIconToolTip="{shuxm:ResourceString Name=ViewPageSettingSetGamePathAction}"
                        Command="{Binding PickGamePathCommand}"
                        Header="{shuxm:ResourceString Name=ViewPageSettingSetGamePathHeader}"
                        HeaderIcon="{shuxm:FontIcon Glyph=&#xE7FC;}"
                        IsClickEnabled="True">
                        <cwc:SettingsCard.Description>
                            <TextBlock Foreground="{ThemeResource SystemErrorTextColor}" Text="{shuxm:ResourceString Name=ViewPageSettingSetGamePathHint}"/>
                        </cwc:SettingsCard.Description>
                    </cwc:SettingsCard>
                </StackPanel>
            </Border>
        </shuxc:StandardView.EmptyContent>

        <Pivot Style="{ThemeResource CardPivotStyle}">
            <Pivot.RightHeader>
                <CommandBar DefaultLabelPosition="Right">
                    <CommandBar.Content>
                        <TextBlock
                            Margin="12,14,12,0"
                            VerticalAlignment="Center"
                            Text="{Binding LaunchStatusOptions.LaunchStatus.Description}"/>
                    </CommandBar.Content>
                    <AppBarButton
                        Command="{Binding OpenScreenshotFolderCommand}"
                        Icon="{shuxm:FontIcon Glyph=&#xED25;}"
                        Label="{shuxm:ResourceString Name=ViewPageOpenScreenshotFolderAction}"/>
                    <AppBarButton
                        Command="{Binding ResetGamePathCommand}"
                        Icon="{shuxm:FontIcon Glyph=&#xEBC4;}"
                        IsEnabled="{Binding LaunchOptions.IsGameRunning.Value, Converter={StaticResource BoolNegationConverter}}"
                        Label="{shuxm:ResourceString Name=ViewPageResetGamePathAction}"
                        ToolTipService.ToolTip="{Binding DisplayGamePath.Value}"/>
                    <AppBarButton
                        Command="{Binding KillGameProcessCommand}"
                        Icon="{shuxm:FontIcon Glyph=&#xE733;}"
                        IsEnabled="{Binding LaunchOptions.CanKillGameProcess.Value}"
                        Label="{shuxm:ResourceString Name=ViewPageLaunchGameKillGameProcessAction}"/>
                    <AppBarButton
                        Command="{Binding LaunchCommand}"
                        Icon="{shuxm:FontIcon Glyph=&#xE7FC;}"
                        IsEnabled="{Binding LaunchOptions.IsGameRunning.Value, Converter={StaticResource BoolNegationConverter}}"
                        Label="{shuxm:ResourceString Name=ViewPageLaunchGameAction}"/>
                </CommandBar>
            </Pivot.RightHeader>

            <PivotItem Header="{shuxm:ResourceString Name=ViewPageLaunchGameOptionsHeader}">
                <Grid>
                    <ScrollViewer>
                        <StackPanel Margin="16" Spacing="16">
                        <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                            <Grid Style="{ThemeResource AcrylicGridCardStyle}">
                                <Grid
                                    Margin="16"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel
                                        Grid.Column="0"
                                        VerticalAlignment="Top"
                                        Spacing="12">
                                        <Grid Style="{ThemeResource GridCardStyle}">
                                            <StackPanel
                                                Padding="16"
                                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,1"
                                                HorizontalAlignment="Center"
                                                Spacing="12">
                                                <shuxci:CachedImage
                                                    shux:FrameworkElementHelper.SquareLength="80"
                                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                                    HorizontalAlignment="Center"
                                                    Source="{StaticResource IconGame}"/>
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    Spacing="4">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="14"
                                                        Text="{Binding GamePackageViewModel.LocalVersionText}"/>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding GamePackageViewModel.RemoteVersionText}"/>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding GamePackageViewModel.SchemeText}"/>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding GamePackageViewModel.GameSizeText}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <Button
                                            Command="{Binding GamePackageViewModel.StartUpdateCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageLaunchGamePackageOperationUpdate}"
                                            HorizontalAlignment="Stretch"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Visibility="{Binding GamePackageViewModel.IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                Grid.Column="0"
                                                Command="{Binding GamePackageViewModel.StartPredownloadCommand}"
                                                Content="{shuxm:ResourceString Name=ViewPageLaunchGamePackageOperationPredownload}"
                                                HorizontalAlignment="Stretch"/>
                                            <Button
                                                Grid.Column="1"
                                                Command="{Binding GamePackageViewModel.StartVerifyCommand}"
                                                Content="{shuxm:ResourceString Name=ViewPageLaunchGamePackageOperationVerify}"
                                                HorizontalAlignment="Stretch"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="12">
                                        <!--  切换服务器  -->
                                        <cwc:SettingsCard
                                            VerticalAlignment="Top"
                                            Description="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchSchemeDescription}"
                                            Header="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchSchemeHeader}"
                                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE8AB;}">
                                            <StackPanel Orientation="Horizontal" Spacing="{ThemeResource SettingsCardContentControlSpacing}">
                                                <Button
                                                    Command="{Binding CleanConvertResourceCommand}"
                                                    Content="{shuxm:ResourceString Name=ViewPageLaunchGameCleanButton}"
                                                    Style="{ThemeResource SettingButtonStyle}"
                                                    ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameCleanTooltip}"/>
                                                <Button
                                                    Command="{Binding ConvertCommand}"
                                                    Content="{shuxm:ResourceString Name=ViewPageLaunchGameSwitchSchemeAction}"
                                                    Style="{ThemeResource SettingButtonStyle}"/>
                                                <shuxc:SizeRestrictedContentControl>
                                                    <shuxc:ComboBox2
                                                        DisplayMemberPath="DisplayName"
                                                        EnableMemberPath="IsNotCompatOnly"
                                                        IsEnabled="{Binding LaunchOptions.IsGameRunning.Value, Converter={StaticResource BoolNegationConverter}}"
                                                        ItemsSource="{Binding KnownSchemes}"
                                                        SelectedItem="{Binding TargetSchemeFilteredGameAccountsView.Scheme, Mode=TwoWay}"
                                                        Style="{StaticResource DefaultComboBoxStyle}"
                                                        ToolTipService.ToolTip="{Binding TargetSchemeFilteredGameAccountsView.Scheme.Description}"/>
                                                </shuxc:SizeRestrictedContentControl>
                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Click="OnServerInfoClick"
                                                    ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameServerInfoTooltip}">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="16" Glyph="&#xE946;"/>
                                                </Button>
                                            </StackPanel>
                                        </cwc:SettingsCard>
                                        <cwc:SettingsCard
                                            Description="{shuxm:ResourceString Name=ViewPageLaunchGameWindowsHDRDescription}"
                                            Header="{shuxm:ResourceString Name=ViewPageLaunchGameWindowsHDRHeader}"
                                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE7F7;}">
                                            <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsWindowsHDREnabled.Value, Mode=TwoWay}"/>
                                        </cwc:SettingsCard>
                                        <cwc:SettingsCard
                                            Description="{shuxm:ResourceString Name=ViewPageLaunchGameHdrManualDescription}"
                                            Header="{shuxm:ResourceString Name=ViewPageLaunchGameHdrManualHeader}"
                                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE771;}">
                                            <ToggleSwitch x:Name="HdrManualToggle" MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" Toggled="OnHdrManualToggled"/>
                                        </cwc:SettingsCard>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  进程  -->
                        <Border Padding="0" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                            <Border Padding="16" Style="{ThemeResource AcrylicBorderCardStyle}">
                                <StackPanel Spacing="{ThemeResource SettingsCardSpacing}">
                                    <cwc:SettingsCard
                                        Description="{shuxm:ResourceString Name=ViewPageLaunchGameUseHoyolabAccountDescription}"
                                        Header="{shuxm:ResourceString Name=ViewPageLaunchGameUseHoyolabAccountHeader}"
                                        HeaderIcon="{shuxm:FontIcon Glyph=&#xE77B;}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <ComboBox
                                                MinWidth="260"
                                                MaxWidth="360"
                                                IsEnabled="{Binding LaunchOptions.UsingHoyolabAccount.Value}"
                                                ItemsSource="{Binding Users.Source}"
                                                SelectedItem="{Binding SelectedLaunchUser, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="shvu:User">
                                                        <Grid Padding="2,4" ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <PersonPicture
                                                                Width="32"
                                                                Height="32"
                                                                ProfilePicture="{Binding UserInfo.AvatarUri, Mode=OneWay, Converter={StaticResource UriToHighResBitmapConverter}}"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                                <TextBlock Text="{Binding UserGameRoles.CurrentItem.Nickname}"/>
                                                                <TextBlock
                                                                    Opacity="0.6"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Text="{Binding UserGameRoles.CurrentItem.Description}"/>
                                                                <TextBlock
                                                                    Opacity="0.4"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Text="{Binding UserInfo.Nickname}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.UsingHoyolabAccount.Value, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </cwc:SettingsCard>

                                    <ScrollViewer>
                                        <cwc:SettingsExpander
                                            shuxc:SettingsExpanderHelper.IsItemsEnabled="{Binding LaunchOptions.AreCommandLineArgumentsEnabled.Value}"
                                            Description="{shuxm:ResourceString Name=ViewPageLaunchGameCommandLineDescription}"
                                            Header="{shuxm:ResourceString Name=ViewPageLaunchGameCommandLineHeader}"
                                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE943;}"
                                            IsExpanded="True">
                                            <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.AreCommandLineArgumentsEnabled.Value, Mode=TwoWay}"/>
                                            <cwc:SettingsExpander.Items>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameWindowedDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameWindowedHeader}">
                                                    <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsWindowed.Value, Mode=TwoWay}" Toggled="OnWindowedChanged"/>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameBorderlessDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameBorderlessHeader}">
                                                    <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsBorderless.Value, Mode=TwoWay}" Toggled="OnBorderlessChanged"/>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameFullScreenDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameFullScreenHeader}">
                                                    <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsFullScreen.Value, Mode=TwoWay}" Toggled="OnFullScreenChanged"/>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameResolutionPresetDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameResolutionPresetHeader}">
                                                    <ComboBox
                                                                                                        MinWidth="{ThemeResource SettingsCardContentControlMinWidth}"
                                                                                                        SelectedIndex="{Binding LaunchOptions.ResolutionPresetIndex.Value, Mode=TwoWay}"
                                                                                                        SelectionChanged="OnResolutionPresetChanged">
                                                        <ComboBoxItem Content="1280x720 (720p HD)"/>
                                                        <ComboBoxItem Content="1366x768 (WXGA)"/>
                                                        <ComboBoxItem Content="1600x900 (HD+)"/>
                                                        <ComboBoxItem Content="1920x1080 (1080p FHD)"/>
                                                        <ComboBoxItem Content="2560x1440 (2K QHD)"/>
                                                        <ComboBoxItem Content="3840x2160 (4K UHD)"/>
                                                        <ComboBoxItem Content="1280x800 (WXGA)"/>
                                                        <ComboBoxItem Content="1440x900 (WXGA+)"/>
                                                        <ComboBoxItem Content="1680x1050 (WSXGA+)"/>
                                                        <ComboBoxItem Content="1920x1200 (WUXGA)"/>
                                                        <ComboBoxItem Content="2560x1600 (WQXGA)"/>
                                                        <ComboBoxItem Content="1024x768 (XGA)"/>
                                                        <ComboBoxItem Content="1280x960 (SXGA-)"/>
                                                        <ComboBoxItem Content="1400x1050 (SXGA+)"/>
                                                        <ComboBoxItem Content="1600x1200 (UXGA)"/>
                                                        <ComboBoxItem Content="1920x1440 (SXGA)"/>
                                                        <ComboBoxItem Content="2560x1080 (UWFHD 21:9)"/>
                                                        <ComboBoxItem Content="3440x1440 (UWQHD 21:9)"/>
                                                        <ComboBoxItem Content="5120x1440 (DUHD 32:9)"/>
                                                        <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameResolutionCustom}"/>
                                                    </ComboBox>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameScreenWidthDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameScreenWidthHeader}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <NumberBox
                                                            MinWidth="{ThemeResource SettingsCardContentControlMinWidth2}"
                                                            Padding="12,6,0,0"
                                                            VerticalAlignment="Center"
                                                            IsEnabled="{Binding LaunchOptions.IsScreenWidthEnabled.Value}"
                                                            Value="{Binding LaunchOptions.ScreenWidth.Value, Mode=TwoWay}"/>
                                                        <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsScreenWidthEnabled.Value, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameScreenHeightDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameScreenHeightHeader}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <NumberBox
                                                            MinWidth="{ThemeResource SettingsCardContentControlMinWidth2}"
                                                            Padding="12,6,0,0"
                                                            VerticalAlignment="Center"
                                                            IsEnabled="{Binding LaunchOptions.IsScreenHeightEnabled.Value}"
                                                            Value="{Binding LaunchOptions.ScreenHeight.Value, Mode=TwoWay}"/>
                                                        <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.IsScreenHeightEnabled.Value, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </cwc:SettingsCard>
                                            </cwc:SettingsExpander.Items>
                                        </cwc:SettingsExpander>
                                    </ScrollViewer>

                                    <ScrollViewer>
                                        <cwc:SettingsExpander
                                            Description="{shuxm:ResourceString Name=ViewPageLaunchGameProgramLinkDescription}"
                                            Header="{shuxm:ResourceString Name=ViewPageLaunchGameProgramLinkHeader}"
                                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE768;}"
                                            IsExpanded="False">
                                            <cwc:SettingsExpander.Items>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameBgiDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameBgiHeader}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <Button Content="{Binding LaunchOptions.BgiPath.Value, Converter={StaticResource FilePathToDisplayNameConverter}, ConverterParameter='bgi'}" MinWidth="{ThemeResource SettingsCardContentControlMinWidth2}" Click="OnSelectBgiPathClick"/>
                                                        <Button Padding="4" MinWidth="0" Click="OnClearBgiPathClick" ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameClearSelection}" Visibility="{Binding LaunchOptions.BgiPath.Value, Converter={StaticResource EmptyStringToVisibilityConverter}}">
                                                            <FontIcon FontSize="12" Glyph="&#xE711;"/>
                                                        </Button>
                                                        <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.UsingBetterGenshinImpactAutomation.Value, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameDelayParamDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameBgiDelayHeader}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ComboBox MinWidth="120" SelectedIndex="{Binding LaunchOptions.BgiDelay.Value, Mode=TwoWay, Converter={StaticResource DelayToIndexConverter}}">
                                                            <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameDelayNone}"/>
                                                            <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameDelay3s}"/>
                                                            <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameDelay5s}"/>
                                                            <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameDelay10s}"/>
                                                            <ComboBoxItem Content="{shuxm:ResourceString Name=ViewPageLaunchGameDelay15s}"/>
                                                        </ComboBox>
                                                        <TextBox MinWidth="160" PlaceholderText="{shuxm:ResourceString Name=ViewPageLaunchGameArgsPlaceholder}" Text="{Binding LaunchOptions.BgiArgs.Value, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameAttachProgram1Description}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameAttachProgram1Header}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <Button Content="{Binding LaunchOptions.AttachProgramPath.Value, Converter={StaticResource FilePathToDisplayNameConverter}}" MinWidth="{ThemeResource SettingsCardContentControlMinWidth2}" Click="OnSelectAttachProgram1Click"/>
                                                        <Button Padding="4" MinWidth="0" Click="OnClearAttachProgram1Click" ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewPageLaunchGameClearSelection}" Visibility="{Binding LaunchOptions.AttachProgramPath.Value, Converter={StaticResource EmptyStringToVisibilityConverter}}">
                                                            <FontIcon FontSize="12" Glyph="&#xE711;"/>
                                                        </Button>
                                                        <ToggleSwitch MinWidth="{ThemeResource SettingsCardContentControlMinWidth}" IsOn="{Binding LaunchOptions.AttachProgramEnabled.Value, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </cwc:SettingsCard>
                                                <cwc:SettingsCard Description="{shuxm:ResourceString Name=ViewPageLaunchGameDelayParamDescription}" Header="{shuxm:ResourceString Name=ViewPageLaunchGameAttachDelay1Header}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ComboBox MinWidth="120" SelectedIndex="{Binding LaunchOptions.AttachProgramDelay.Value, Mode=TwoWay, Converter={StaticResource DelayToIndexConverter}}">
