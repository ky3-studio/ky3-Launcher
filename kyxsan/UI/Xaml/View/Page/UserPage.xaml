<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.UserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shux="using:kyxsan.UI.Xaml"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxba="using:kyxsan.UI.Xaml.Behavior.Action"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxdcs="using:kyxsan.UI.Xaml.Data.Converter.Specialized"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shuxvww="using:kyxsan.UI.Xaml.View.Window.WebView2"
    xmlns:shvu="using:kyxsan.ViewModel.User"
    xmlns:shwhtb="using:kyxsan.Web.Hoyolab.Takumi.Binding"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    d:DataContext="{d:DesignInstance shvu:UserViewModel}"
    mc:Ignorable="d">

    <shuxc:ScopedPage.Resources>
        <shuxdcs:ThirdPartyIconConverter x:Key="ThirdPartyIconConverter"/>
        <shuxdcs:ThirdPartyIconUriConverter x:Key="ThirdPartyIconUriConverter"/>
        <shuxdcs:UriToHighResBitmapConverter x:Key="UriToHighResBitmapConverter"/>
        <shux:BindingProxy x:Key="ViewModelBindingProxy" DataContext="{Binding}"/>

        <DataTemplate x:Key="UserGameRoleTemplate" x:DataType="shwhtb:UserGameRole">
            <Grid Padding="0,12" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <shuxci:CachedImage
                    Grid.Column="0"
                    Height="32"
                    Margin="2,0"
                    HorizontalAlignment="Left"
                    Background="#FFDAB79B"
                    CornerRadius="{ThemeResource CornerRadiusAll16}"
                    Source="{Binding ProfilePictureIcon, Converter={StaticResource AvatarIconCircleConverter}}"/>
                <Button
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="2,0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Command="{Binding RefreshProfilePictureCommand}"
                    CommandParameter="{Binding}"
                    CornerRadius="{ThemeResource CornerRadiusAll16}">
                    <Button.Resources>
                        <Storyboard x:Key="ShowRefreshIcon">
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0">
                                    <DiscreteObjectKeyFrame.Value>
                                        <Visibility>Visible</Visibility>
                                    </DiscreteObjectKeyFrame.Value>
                                </DiscreteObjectKeyFrame>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="HideRefreshIcon">
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RefreshIcon" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0">
                                    <DiscreteObjectKeyFrame.Value>
                                        <Visibility>Collapsed</Visibility>
                                    </DiscreteObjectKeyFrame.Value>
                                </DiscreteObjectKeyFrame>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </Button.Resources>
                    <mxi:Interaction.Behaviors>
                        <mxi:EventTriggerBehavior EventName="PointerEntered">
                            <mxi:ControlStoryboardAction Storyboard="{StaticResource ShowRefreshIcon}"/>
                        </mxi:EventTriggerBehavior>
                        <mxi:EventTriggerBehavior EventName="PointerExited">
                            <mxi:ControlStoryboardAction Storyboard="{StaticResource HideRefreshIcon}"/>
                        </mxi:EventTriggerBehavior>
                    </mxi:Interaction.Behaviors>
                    <FontIcon
                        x:Name="RefreshIcon"
                        FontSize="12"
                        Glyph="&#xE72C;"
                        Visibility="Collapsed"/>
                </Button>
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Text="{Binding Nickname}"/>
                    <TextBlock
                        Margin="0,2,0,0"
                        Opacity="0.6"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding Description}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="UserTemplate" x:DataType="shvu:User">
            <Grid Padding="0,12" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Grid.Resources>
                    <Storyboard x:Name="ButtonPanelVisibleStoryboard">
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonPanel" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Visible</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoYoLABLabel" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Collapsed</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>

                    <Storyboard x:Name="ButtonPanelCollapsedStoryboard">
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonPanel" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Collapsed</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HoYoLABLabel" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Visible</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </Grid.Resources>

                <mxi:Interaction.Behaviors>
                    <mxi:EventTriggerBehavior EventName="PointerEntered">
                        <mxi:ControlStoryboardAction Storyboard="{StaticResource ButtonPanelVisibleStoryboard}"/>
                    </mxi:EventTriggerBehavior>
                    <mxi:EventTriggerBehavior EventName="PointerExited">
                        <mxi:ControlStoryboardAction Storyboard="{StaticResource ButtonPanelCollapsedStoryboard}"/>
                    </mxi:EventTriggerBehavior>
                </mxi:Interaction.Behaviors>
                <PersonPicture
                    Height="32"
                    Margin="2,0"
                    HorizontalAlignment="Left"
                    ProfilePicture="{Binding UserInfo.AvatarUri, Mode=OneWay, Converter={StaticResource UriToHighResBitmapConverter}}"/>
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding UserInfo.Nickname}"/>
                <Border
                    x:Name="HoYoLABLabel"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Visibility="Visible">
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="HoYoLAB"
                        Visibility="{Binding IsOversea}"/>
                </Border>

                <StackPanel
                    x:Name="ButtonPanel"
                    Grid.Column="3"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <Button
                        Margin="12,0,0,0"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Command="{Binding DataContext.CopyCookieCommand, Source={StaticResource ViewModelBindingProxy}}"
                        CommandParameter="{Binding}"
                        Content="{StaticResource FontIconContentCopy}"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Style="{StaticResource ButtonRevealStyle}"
                        ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewUserCopyCookieAction}"/>
                    <Button
                        Margin="6,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Command="{Binding DataContext.RemoveUserCommand, Source={StaticResource ViewModelBindingProxy}}"
                        CommandParameter="{Binding}"
                        Content="{StaticResource FontIconContentDelete}"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Style="{StaticResource ButtonRevealStyle}"
                        ToolTipService.ToolTip="{shuxm:ResourceString Name=ViewUserRemoveAction}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </shuxc:ScopedPage.Resources>

    <Grid>
        <Border Background="#40000000"/>
        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
            Visibility="{Binding Users.Count, Converter={StaticResource Int32ToVisibilityRevertConverter}}">
                <Border
                    MinWidth="480"
                    Padding="16"
                    Style="{ThemeResource AcrylicBorderCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{shuxm:ResourceString Name=ViewCommonLoginRequiredHint}"/>
                        <StackPanel Margin="0,0,0,0" Spacing="{StaticResource SettingsCardSpacing}">
                            <cwcont:SettingsCard
                                Command="{Binding LoginByQRCodeCommand}"
                                Description="{shuxm:ResourceString Name=ViewCommonLoginQRCodeDescription}"
                                Header="{shuxm:ResourceString Name=ViewCommonLoginQRCodeHeader}"
                                HeaderIcon="{shuxm:FontIcon Glyph=&#xED14;}"
                                IsClickEnabled="True"/>
                            <cwcont:SettingsCard
                                Command="{Binding LoginByMobileCaptchaCommand}"
                                Description="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaDescription}"
                                Header="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaHeader}"
                                HeaderIcon="{shuxm:FontIcon Glyph=&#xE8EA;}"
                                IsClickEnabled="True"/>
                            <cwcont:SettingsCard
                                Command="{Binding AddUserCommand}"
                                Description="{shuxm:ResourceString Name=ViewCommonLoginManualInputDescription}"
                                Header="{shuxm:ResourceString Name=ViewCommonLoginManualInputHeader}"
                                HeaderIcon="{shuxm:FontIcon Glyph=&#xE109;}"
                                IsClickEnabled="True"/>
                        </StackPanel>
                        
                        <TextBlock
                            Margin="0,16,0,8"
                            HorizontalAlignment="Center"
                            Style="{StaticResource BaseTextBlockStyle}"
                            Text="{shuxm:ResourceString Name=ViewUserOverseaLoginTitle}"/>
                        <StackPanel Margin="0,0,0,0" Spacing="{StaticResource SettingsCardSpacing}">
                            <cwcont:SettingsCard
                                Description="{shuxm:ResourceString Name=ViewUserOverseaThirdPartyDescription}"
                                Header="{shuxm:ResourceString Name=ViewUserOverseaThirdPartyHeader}">
                                <cwcont:SettingsCard.Content>
                                    <ItemsControl
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Right"
                                        ItemsSource="{Binding OverseaThirdPartyKinds}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Width="56"
                                                    Height="56"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.LoginByThirdPartyOverseaCommand, Source={StaticResource ViewModelBindingProxy}}"
                                                    CommandParameter="{Binding Value}"
                                                    CornerRadius="8">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#15FFFFFF"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#25FFFFFF"/>
                                                    </Button.Resources>
                                                    <Image
                                                        Width="40"
                                                        Height="40"
                                                        Source="{Binding Name, Converter={StaticResource ThirdPartyIconUriConverter}}"
                                                        Stretch="Uniform"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </cwcont:SettingsCard.Content>
                            </cwcont:SettingsCard>
                            
                            <cwcont:SettingsCard
                                Command="{Binding LoginByPasswordOverseaCommand}"
                                Description="{shuxm:ResourceString Name=ViewUserOverseaPasswordDescription}"
                                Header="{shuxm:ResourceString Name=ViewUserOverseaPasswordHeader}"
                                HeaderIcon="{shuxm:FontIcon Glyph=&#xE77B;}"
                                IsClickEnabled="True"/>
                            <cwcont:SettingsCard
                                Command="{Binding AddOverseaUserCommand}"
                                Description="{shuxm:ResourceString Name=ViewUserOverseaManualInputDescription}"
                                Header="{shuxm:ResourceString Name=ViewCommonLoginManualInputHeader}"
                                HeaderIcon="{shuxm:FontIcon Glyph=&#xE109;}"
                                IsClickEnabled="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
            
            <ScrollViewer Visibility="{Binding Users.Count, Converter={StaticResource Int32ToVisibilityConverter}}">
                <StackPanel MaxWidth="900" Margin="16,16,16,16" HorizontalAlignment="Center" Spacing="16">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}" Padding="16">
                        <StackPanel Spacing="12" Visibility="{Binding Users.CurrentItem, Converter={StaticResource EmptyObjectToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewUserCurrentAccountHeader}"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <PersonPicture
                                    Width="64"
                                    Height="64"
                                    Margin="0,0,16,0"
                                    ProfilePicture="{Binding Users.CurrentItem.UserInfo.AvatarUri, Mode=OneWay, Converter={StaticResource UriToHighResBitmapConverter}}"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock
                                        Style="{StaticResource TitleTextBlockStyle}"
                                        Text="{Binding Users.CurrentItem.UserInfo.Nickname}"
                                        TextWrapping="Wrap"/>
                                    <TextBlock
                                        Opacity="0.7"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        TextWrapping="Wrap">
                                        <Run Text="UID: "/>
                                        <Run Text="{Binding Users.CurrentItem.UserGameRoles.CurrentItem.GameUid, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border
                                            Padding="8,4"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Visibility="{Binding Users.CurrentItem.IsOversea}">
                                            <TextBlock
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="HoYoLAB"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{ThemeResource AcrylicBorderCardStyle}" Padding="16" Visibility="{Binding Users.CurrentItem, Converter={StaticResource EmptyObjectToVisibilityConverter}, Mode=OneWay}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewUserRole}"/>
                            <ListView
                                ItemTemplate="{StaticResource UserGameRoleTemplate}"
                                ItemsSource="{Binding Users.CurrentItem.UserGameRoles}"
                                SelectedItem="{Binding Users.CurrentItem.UserGameRoles.CurrentItem, Mode=TwoWay}"
                                SelectionMode="Single"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{ThemeResource AcrylicBorderCardStyle}" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewUserUser}"/>
                            <ListView
                                AllowDrop="{shuxm:IsProcessNotElevated}"
                                CanReorderItems="{shuxm:IsProcessNotElevated}"
                                ItemTemplate="{StaticResource UserTemplate}"
                                ItemsSource="{Binding Users}"
                                SelectedItem="{Binding Users.CurrentItem, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.Header>
                                    <InfoBar
                                        Title="{shuxm:ResourceString Name=ViewListViewDragElevatedHint}"
                                        Margin="4,0,4,2"
                                        IsClosable="True"
                                        IsOpen="True"
                                        Severity="Warning"
                                        Visibility="{shuxm:VisibleWhenProcessElevated}"/>
                                </ListView.Header>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
        </ScrollViewer>
    </Grid>
</shuxc:ScopedPage>
