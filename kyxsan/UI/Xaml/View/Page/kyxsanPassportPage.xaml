<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.kyxsanPassportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwb="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shvh="using:kyxsan.ViewModel.kyxsanPassport"
    d:DataContext="{d:DesignInstance shvh:kyxsanPassportViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <Grid>
        <Border Background="#40000000"/>
        <ScrollViewer>
        <StackPanel Padding="16" Spacing="16">
            <Border VerticalAlignment="Top" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Padding="16" Style="{ThemeResource AcrylicBorderCardStyle}">
                    <StackPanel Spacing="{ThemeResource SettingsCardSpacing}">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="{ThemeResource SettingsCardSpacing}">
                                <cwc:SettingsCard
                                    Description="{Binding kyxsanUserOptions.UserName}"
                                    Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportHeader}"
                                    HeaderIcon="{shuxm:FontIcon Glyph=&#xE716;}">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <Button
                                            Command="{Binding LoginCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportLoginAction}"
                                            Style="{ThemeResource SettingButtonStyle}"
                                            Visibility="{Binding kyxsanUserOptions.IsLoggedIn, Converter={StaticResource BoolToVisibilityRevertConverter}}"/>
                                        <Button
                                            Command="{Binding RegisterCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportRegisterAction}"
                                            Style="{ThemeResource SettingButtonStyle}"
                                            Visibility="{Binding kyxsanUserOptions.IsLoggedIn, Converter={StaticResource BoolToVisibilityRevertConverter}}"/>
                                        <Button
                                            Command="{Binding RefreshUserInfoCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportRefreshAction}"
                                            Style="{ThemeResource SettingButtonStyle}"
                                            Visibility="{Binding kyxsanUserOptions.IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <Button
                                            Command="{Binding LogoutCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportLogoutAction}"
                                            Style="{ThemeResource SettingButtonStyle}"
                                            Visibility="{Binding kyxsanUserOptions.IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </cwc:SettingsCard>
                                <cwc:SettingsCard
                                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                    Description="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportLicensedDeveloperDescription}"
                                    Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportLicensedDeveloperHeader}"
                                    Visibility="{Binding kyxsanUserOptions.IsDeveloper, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button
                                        Command="{Binding OpenTestPageCommand}"
                                        Content="TEST"
                                        Style="{ThemeResource SettingButtonStyle}"/>
                                </cwc:SettingsCard>
                                <cwc:SettingsCard
                                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                    Description="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportMaintainerDescription}"
                                    Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportMaintainerHeader}"
                                    Visibility="{Binding kyxsanUserOptions.IsMaintainer, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <cwc:SettingsCard
                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                    Description="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportDangerZoneDescription}"
                                    Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportDangerZoneHeader}">
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <Button
                                            Command="{Binding ResetUsernameCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportResetUserNameAction}"
                                            Style="{ThemeResource SettingButtonStyle}"/>
                                        <Button
                                            Command="{Binding ResetPasswordCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportResetPasswordAction}"
                                            Style="{ThemeResource SettingButtonStyle}"/>
                                        <Button
                                            Command="{Binding UnregisterCommand}"
                                            Content="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportUnregisterAction}"
                                            Style="{ThemeResource SettingButtonStyle}"/>
                                    </StackPanel>
                                </cwc:SettingsCard>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Border>

            <Border VerticalAlignment="Top" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Padding="16" Style="{ThemeResource AcrylicBorderCardStyle}">
                    <StackPanel Spacing="{ThemeResource SettingsCardSpacing}">
                        <InfoBar
                            Title="{shuxm:ResourceString Name=ViewPagekyxsanPassportCDNCloudHeader}"
                            IsClosable="False"
                            IsOpen="True"
                            Message="{shuxm:ResourceString Name=ViewPagekyxsanPassportCDNCloudDescription}"/>
                        <cwc:SettingsCard Description="{Binding kyxsanUserOptions.CdnExpireAt}" Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportCdnExpiredAtHeader}">
                            <Button Content="{shuxm:ResourceString Name=ViewPagekyxsanPassportSponsorAction}" Style="{ThemeResource SettingButtonStyle}">
                                <mxi:Interaction.Behaviors>
                                    <mxi:EventTriggerBehavior EventName="Click">
                                        <cwb:NavigateToUriAction NavigateUri="https://afdian.com/item/274f5a7cbe9911efab6552540025c377"/>
                                    </mxi:EventTriggerBehavior>
                                </mxi:Interaction.Behaviors>
                            </Button>
                        </cwc:SettingsCard>
                        <cwc:SettingsCard
                            Command="{Binding UseRedeemCodeCommand}"
                            Description="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportRedeemCodeDescription}"
                            Header="{shuxm:ResourceString Name=ViewPageSettingkyxsanPassportRedeemCodeHeader}"
                            IsClickEnabled="True"/>
                    </StackPanel>
                </Border>
            </Border>
        </StackPanel>

    </ScrollViewer>
    </Grid>
</shuxc:ScopedPage>