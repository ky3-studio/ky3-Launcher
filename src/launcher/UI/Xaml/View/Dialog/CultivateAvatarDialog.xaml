<ContentDialog
    x:Class="Launcher.UI.Xaml.View.Dialog.CultivateAvatarDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shmma="using:Launcher.Model.Metadata.Avatar"
    xmlns:shuxc="using:Launcher.UI.Xaml.Control"
    xmlns:shuxcc="using:Launcher.UI.Xaml.Control.Card"
    xmlns:shuxm="using:Launcher.UI.Xaml.Markup"
    Title="{shuxm:ResourceString Name=ViewDialogAvatarPropertyMultiAvatarCultivateSelectTitle}"
    CloseButtonText="{shuxm:ResourceString Name=ContentDialogCancelCloseButtonText}"
    DefaultButton="Primary"
    PrimaryButtonText="{shuxm:ResourceString Name=ContentDialogConfirmPrimaryButtonText}"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">920</x:Double>
        <DataTemplate x:Key="AvatarGridTemplate" x:DataType="shmma:Avatar">
            <shuxcc:VerticalCard Width="82">
                <shuxcc:VerticalCard.Top>
                    <shuxc:ItemIcon Icon="{Binding Icon, Converter={StaticResource AvatarIconConverter}, Mode=OneWay}" Quality="{Binding Quality}"/>
                </shuxcc:VerticalCard.Top>
                <shuxcc:VerticalCard.Bottom>
                    <TextBlock
                        Margin="2,0"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis"/>
                </shuxcc:VerticalCard.Bottom>
            </shuxcc:VerticalCard>
        </DataTemplate>
    </ContentDialog.Resources>

    <Grid Width="840" Height="520">
        <GridView
            x:Name="AvatarGridView"
            HorizontalAlignment="Center"
            HorizontalContentAlignment="Center"
            ItemContainerStyle="{StaticResource LargeGridViewItemStyle}"
            ItemTemplate="{StaticResource AvatarGridTemplate}"
            SelectionMode="Multiple"/>
    </Grid>
</ContentDialog>
