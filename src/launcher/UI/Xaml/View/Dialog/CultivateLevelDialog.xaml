<ContentDialog
    x:Class="Launcher.UI.Xaml.View.Dialog.CultivateLevelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:cwconv="using:CommunityToolkit.WinUI.Converters"
    xmlns:local="using:Launcher.UI.Xaml.View.Dialog"
    xmlns:shuxc="using:Launcher.UI.Xaml.Control"
    xmlns:shuxci="using:Launcher.UI.Xaml.Control.Image"
    xmlns:shuxm="using:Launcher.UI.Xaml.Markup"
    Title="{shuxm:ResourceString Name=ViewDialogCultivateLevelTitle}"
    CloseButtonText="{shuxm:ResourceString Name=ContentDialogCancelCloseButtonText}"
    DefaultButton="Primary"
    PrimaryButtonText="{shuxm:ResourceString Name=ContentDialogConfirmPrimaryButtonText}"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">920</x:Double>
        <cwconv:BoolToObjectConverter x:Key="BoolToVisibilityConverter" TrueValue="Visible" FalseValue="Collapsed"/>
    </ContentDialog.Resources>

    <ScrollViewer
        MaxHeight="600"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="AvatarItemsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:CultivateAvatarLevelItem">
                    <StackPanel MinWidth="480" Margin="0,0,0,12" Spacing="4">
                        <!-- Avatar Level Row -->
                        <Border Padding="8" Style="{ThemeResource BorderCardStyle}">
                            <Grid Height="36" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <shuxc:ItemIcon
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Icon="{Binding AvatarIcon, Mode=OneWay}"
                                    Quality="{Binding AvatarQuality}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{Binding AvatarName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"/>
                                <NumberBox
                                    Grid.Column="2"
                                    Maximum="90"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding AvatarLevelFrom, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Text="→"/>
                                <NumberBox
                                    Grid.Column="4"
                                    Maximum="90"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding AvatarLevelTo, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <!-- Skill A Row -->
                        <Border Padding="8" Style="{ThemeResource BorderCardStyle}">
                            <Grid Height="36" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <shuxci:CachedImage
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Source="{Binding SkillAIcon, Mode=OneWay}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding SkillAName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"/>
                                <NumberBox
                                    Grid.Column="2"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillALevelFrom, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Text="→"/>
                                <NumberBox
                                    Grid.Column="4"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillALevelTo, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <!-- Skill E Row -->
                        <Border Padding="8" Style="{ThemeResource BorderCardStyle}">
                            <Grid Height="36" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <shuxci:CachedImage
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Source="{Binding SkillEIcon, Mode=OneWay}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding SkillEName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"/>
                                <NumberBox
                                    Grid.Column="2"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillELevelFrom, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Text="→"/>
                                <NumberBox
                                    Grid.Column="4"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillELevelTo, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <!-- Skill Q Row -->
                        <Border Padding="8" Style="{ThemeResource BorderCardStyle}">
                            <Grid Height="36" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <shuxci:CachedImage
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Source="{Binding SkillQIcon, Mode=OneWay}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding SkillQName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"/>
                                <NumberBox
                                    Grid.Column="2"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillQLevelFrom, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Text="→"/>
                                <NumberBox
                                    Grid.Column="4"
                                    Maximum="10"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding SkillQLevelTo, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <!-- Weapon Section -->
                        <Border
                            Margin="0,4,0,0"
                            Padding="8"
                            Style="{ThemeResource BorderCardStyle}"
                            Visibility="{Binding HasWeapon, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Height="36" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <shuxc:ItemIcon
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Icon="{Binding WeaponIcon, Mode=OneWay}"
                                    Quality="{Binding WeaponQuality}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{Binding WeaponName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"/>
                                <CheckBox
                                    Grid.Column="2"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="已突破"
                                    IsChecked="{Binding WeaponAscended, Mode=TwoWay}"
                                    Visibility="{Binding WeaponPromotionAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <NumberBox
                                    Grid.Column="3"
                                    Maximum="90"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding WeaponLevelFrom, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Column="4"
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Text="→"/>
                                <NumberBox
                                    Grid.Column="5"
                                    Maximum="90"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{Binding WeaponLevelTo, Mode=TwoWay}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</ContentDialog>
