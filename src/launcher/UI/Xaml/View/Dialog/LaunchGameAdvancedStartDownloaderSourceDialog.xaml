<ContentDialog
    x:Class="kyxsan.UI.Xaml.View.Dialog.LaunchGameAdvancedStartDownloaderSourceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:kyxsan.UI.Xaml.View.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    Title="{shuxm:ResourceString Name=ViewDialogLaunchGameAdvancedStartSourceSetterTitle}"
    CloseButtonText="{shuxm:ResourceString Name=ViewWindowExceptionClose}"
    Loaded="OnLoaded"
    PrimaryButtonClick="OnPrimaryButtonClick"
    PrimaryButtonText="{shuxm:ResourceString Name=ContentDialogSavePrimaryButtonText}"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Spacing="{ThemeResource SettingsCardContentControlSpacing}">
        <TextBlock Text="{shuxm:ResourceString Name=ViewDialogLaunchGameAdvancedStartSourceDescription}" TextWrapping="Wrap"/>
        <TextBox x:Name="ViewDialogLaunchGameAdvancedStartSourceSetterEndpointTextBox"/>
        <Button Click="Button_Click" Content="{shuxm:ResourceString Name=ViewDialogLaunchGameAdvancedStartSourceSetterBackToDefaultButton}"/>
    </StackPanel>
</ContentDialog>
