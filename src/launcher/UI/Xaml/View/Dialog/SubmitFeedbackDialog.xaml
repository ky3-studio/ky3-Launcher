<ContentDialog
    x:Class="kyxsan.UI.Xaml.View.Dialog.SubmitFeedbackDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="提交反馈"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonText="提交"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Spacing="10" MinWidth="380">

        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="反馈内容"/>
        <TextBox
            x:Name="ContentBox"
            AcceptsReturn="True"
            MaxHeight="120"
            PlaceholderText="请描述您遇到的问题或建议（必填）..."
            TextWrapping="Wrap"/>

        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="联系方式（可选）"/>
        <TextBox
            x:Name="ContactBox"
            PlaceholderText="QQ / 微信 / 邮箱"/>

        <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="附件图片（可选）"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="ImageNameText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="未选择图片"
                TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <Button x:Name="PickImageBtn" Click="PickImage_Click" Content="选择图片"/>
                <Button
                    x:Name="ClearImageBtn"
                    Click="ClearImage_Click"
                    Content="✕"
                    IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <ProgressBar x:Name="UploadProgress" IsIndeterminate="True" Visibility="Collapsed"/>
        <TextBlock
            x:Name="StatusText"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
            TextWrapping="Wrap"
            Visibility="Collapsed"/>

    </StackPanel>

</ContentDialog>
