<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.AnnouncementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwa="using:CommunityToolkit.WinUI.Animations"
    xmlns:cww="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxba="using:kyxsan.UI.Xaml.Behavior.Action"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxcc="using:kyxsan.UI.Xaml.Control.Card"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxcp="using:kyxsan.UI.Xaml.Control.Panel"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shuxma="using:kyxsan.UI.Xaml.Media.Animation"
    xmlns:shuxvww="using:kyxsan.UI.Xaml.View.Window.WebView2"
    xmlns:shvc="using:kyxsan.ViewModel.Calendar"
    xmlns:shvh="using:kyxsan.ViewModel.Home"
    xmlns:shwhhca="using:kyxsan.Web.Hoyolab.Hk4e.Common.Announcement"
    d:DataContext="{d:DesignInstance shvh:AnnouncementViewModel}"
    Background="Transparent"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <shuxc:ScopedPage.Resources>
        <DataTemplate x:Key="AnnouncementTemplate" x:DataType="shwhhca:Announcement">
            <ItemContainer cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Background="{ThemeResource SystemControlAcrylicElementMediumHighBrush}" Style="{StaticResource AcrylicBorderCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <!--  Image Layer  -->
                        <Border cw:UIElementExtensions.ClipToBounds="True" CornerRadius="{ThemeResource ControlCornerRadiusTop}">
                            <Grid>
                                <Border
                                    x:Name="ImageZoomBorder"
                                    VerticalAlignment="Top"
                                    cw:VisualExtensions.NormalizedCenterPoint="0.5">
                                    <cww:ConstrainedBox
                                        Margin="-4"
                                        AspectRatio="1080:390"
                                        CornerRadius="{ThemeResource ControlCornerRadiusTop}">
                                        <shuxci:CachedImage
                                            VerticalAlignment="Center"
                                            Source="{Binding Banner}"
                                            Stretch="UniformToFill"/>
                                    </cww:ConstrainedBox>
                                    <cwa:Explicit.Animations>
                                        <cwa:AnimationSet x:Name="ImageZoomInAnimation">
                                            <shuxma:ImageZoomInAnimation/>
                                        </cwa:AnimationSet>
                                        <cwa:AnimationSet x:Name="ImageZoomOutAnimation">
                                            <shuxma:ImageZoomOutAnimation/>
                                        </cwa:AnimationSet>
                                    </cwa:Explicit.Animations>
                                </Border>
                                <Border Background="{ThemeResource DarkOnlyOverlayMaskColorBrush}" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <!--  General Description  -->
                        <Border Grid.Row="1">
                            <StackPanel
                                Margin="4"
                                Padding="4"
                                VerticalAlignment="Bottom"
                                Spacing="6">
                                <TextBlock
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="{Binding Subtitle}"
                                    TextTrimming="WordEllipsis"
                                    TextWrapping="NoWrap"/>

                                <TextBlock
                                    Opacity="0.6"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Text="{Binding Title}"
                                    TextTrimming="WordEllipsis"
                                    TextWrapping="NoWrap"/>

                                <Grid Visibility="{Binding ShouldShowTimeDescription, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ProgressBar
                                        Height="3"
                                        Margin="0,2,0,4"
                                        CornerRadius="2"
                                        Maximum="1"
                                        Minimum="0"
                                        Visibility="{Binding ShouldShowTimePercent, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Value="{Binding TimePercent}"/>
                                    <TextBlock
                                        Grid.Row="1"
                                        Opacity="0.5"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{Binding TimeDescription}"/>
                                    <TextBlock
                                        Grid.Row="2"
                                        Margin="0,2,0,0"
                                        Opacity="0.35"
                                        FontSize="11"
                                        Text="{Binding TimeFormatted}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <mxi:Interaction.Behaviors>
                        <mxi:EventTriggerBehavior EventName="Tapped">
                            <shuxba:ShowWebView2WindowAction>
                                <shuxba:ShowWebView2WindowAction.ContentProvider>
                                    <shuxvww:AnnouncementWebView2ContentProvider Announcement="{Binding}"/>
                                </shuxba:ShowWebView2WindowAction.ContentProvider>
                            </shuxba:ShowWebView2WindowAction>
                        </mxi:EventTriggerBehavior>
                        <mxi:EventTriggerBehavior EventName="PointerEntered">
                            <shuxba:StartAnimationActionNoThrow Animation="{Binding ElementName=ImageZoomInAnimation}" TargetObject="{Binding ElementName=ImageZoomBorder}"/>
                        </mxi:EventTriggerBehavior>
                        <mxi:EventTriggerBehavior EventName="PointerExited">
                            <shuxba:StartAnimationActionNoThrow Animation="{Binding ElementName=ImageZoomOutAnimation}" TargetObject="{Binding ElementName=ImageZoomBorder}"/>
                        </mxi:EventTriggerBehavior>
                    </mxi:Interaction.Behaviors>
                </Border>
            </ItemContainer>
        </DataTemplate>

        <DataTemplate x:Key="AnnouncementPivotItemContentTemplate" x:DataType="shwhhca:AnnouncementListWrapper">
            <ItemsControl ItemTemplate="{StaticResource AnnouncementTemplate}" ItemsSource="{Binding List}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <shuxcp:UniformPanel
                            Margin="16"
                            ColumnSpacing="12"
                            MinItemWidth="300"
                            RowSpacing="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>
    </shuxc:ScopedPage.Resources>

    <Grid>
        <Border Background="#40000000"/>
        <ScrollViewer Padding="0" Style="{StaticResource DefaultScrollViewerStyle}">
            <StackPanel Padding="16" Spacing="16">

                <!--  Calendar  -->
                <Border
                    cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
                    Visibility="{Binding WeekDays, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                    <Border Padding="12" Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <cww:Segmented
                                Grid.Row="0"
                                Height="48"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding WeekDays}"
                                Style="{ThemeResource DefaultSegmentedStyle}">
                                <cww:Segmented.ItemTemplate>
                                    <DataTemplate x:DataType="shvc:CalendarDay">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock
                                                Grid.Row="0"
                                                HorizontalAlignment="Center"
                                                Text="{Binding DayInMonth}"/>
                                            <TextBlock
                                                Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                Opacity="0.7"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{Binding DayName}"/>
                                        </Grid>
                                    </DataTemplate>
                                </cww:Segmented.ItemTemplate>
                            </cww:Segmented>

                            <Grid
                                Grid.Row="1"
                                DataContext="{Binding WeekDays.CurrentItem, FallbackValue={x:Null}}"
                                RowSpacing="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!--  Birthday avatars  -->
                                <ItemsControl
                                    Grid.Row="0"
                                    HorizontalAlignment="Left"
                                    ItemsPanel="{ThemeResource WrapPanelSpacing6Template}"
                                    ItemsSource="{Binding BirthDayAvatars}"
                                    Visibility="{Binding BirthDayAvatars.IsEmpty, Converter={StaticResource BoolToVisibilityRevertConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <shuxcc:HorizontalCard>
                                                <shuxcc:HorizontalCard.Left>
                                                    <shuxc:ItemIcon
                                                        Width="32"
                                                        Height="32"
                                                        Icon="{Binding Icon}"
                                                        Quality="{Binding Quality}"/>
                                                </shuxcc:HorizontalCard.Left>
                                                <shuxcc:HorizontalCard.Right>
                                                    <TextBlock Margin="6,0" Text="{Binding Name}"/>
                                                </shuxcc:HorizontalCard.Right>
                                            </shuxcc:HorizontalCard>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!--  Materials Grid  -->
                                <ItemsControl
                                    Grid.Row="1"
                                    ItemsSource="{Binding Materials}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <shuxcp:UniformPanel
                                                ColumnSpacing="8"
                                                MinItemWidth="160"
                                                RowSpacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="8"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <StackPanel Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <shuxc:ItemIcon
                                                            Width="36"
                                                            Height="36"
                                                            Icon="{Binding Inner.Icon, Converter={StaticResource ItemIconConverter}}"
                                                            Quality="{Binding Inner.RankLevel}"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock
                                                                MaxWidth="100"
                                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                                Text="{Binding Inner.Name}"
                                                                TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock
                                                                Opacity="0.5"
                                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                                Text="{Binding Inner.TypeDescription}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ItemsControl
                                                        ItemsPanel="{ThemeResource WrapPanelSpacing4Template}"
                                                        ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <shuxc:ItemIcon
                                                                    Width="32"
                                                                    Height="32"
                                                                    Icon="{Binding Icon}"
                                                                    Quality="{Binding Quality}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>

                <Pivot
                    x:Name="GameAnnouncementPivot"
                    Margin="-16"
                    x:Load="False"
                    Style="{ThemeResource CardPivotStyle}"
                    Transitions="{ThemeResource EntranceThemeTransitions}">
                    <PivotItem
                        Content="{Binding Announcement.List[1]}"
                        ContentTemplate="{StaticResource AnnouncementPivotItemContentTemplate}"
                        Header="{Binding Announcement.TypeList[1].MI18NName}"/>
                    <PivotItem
                        Content="{Binding Announcement.List[0]}"
                        ContentTemplate="{StaticResource AnnouncementPivotItemContentTemplate}"
                        Header="{Binding Announcement.TypeList[0].MI18NName}"/>
                    <PivotItem
                        Content="{Binding Announcement.List[2]}"
                        ContentTemplate="{StaticResource AnnouncementPivotItemContentTemplate}"
                        Header="{Binding Announcement.TypeList[2].MI18NName}"/>
                </Pivot>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</shuxc:ScopedPage>