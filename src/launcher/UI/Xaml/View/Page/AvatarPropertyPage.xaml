<shuxc:ScopedPage
    x:Class="Launcher.UI.Xaml.View.Page.AvatarPropertyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:clw="using:CommunityToolkit.Labs.WinUI"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:cwconv="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shuxc="using:Launcher.UI.Xaml.Control"
    xmlns:shuxca="using:Launcher.UI.Xaml.Control.AutoSuggestBox"
    xmlns:shuxcc="using:Launcher.UI.Xaml.Control.Card"
    xmlns:shuxci="using:Launcher.UI.Xaml.Control.Image"
    xmlns:shuxcp="using:Launcher.UI.Xaml.Control.Panel"
    xmlns:shuxct="using:Launcher.UI.Xaml.Control.TextBlock"
    xmlns:shuxdcs="using:Launcher.UI.Xaml.Data.Converter.Specialized"
    xmlns:shuxm="using:Launcher.UI.Xaml.Markup"
    xmlns:shmm="using:Launcher.Model.Metadata"
    xmlns:shvap="using:Launcher.ViewModel.AvatarProperty"
    xmlns:shwga="using:Launcher.Web.Hoyolab.Takumi.GameRecord.Avatar"
    d:DataContext="{d:DesignInstance shvap:AvatarPropertyViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <shuxdcs:UInt32ToGradientColorConverter
                        x:Key="CountToGradientColorConverter"
                        Maximum="#FFFD0093"
                        Minimum="#FF4B00D9"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <shuxdcs:UInt32ToGradientColorConverter
                        x:Key="CountToGradientColorConverter"
                        Maximum="#FFFF69BF"
                        Minimum="#FF9F69FF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <cwconv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <cwconv:BoolToObjectConverter x:Key="BoolToOpacityConverter">
                <cwconv:BoolToObjectConverter.TrueValue>
                    <x:Double>1</x:Double>
                </cwconv:BoolToObjectConverter.TrueValue>
                <cwconv:BoolToObjectConverter.FalseValue>
                    <x:Double>0.5</x:Double>
                </cwconv:BoolToObjectConverter.FalseValue>
            </cwconv:BoolToObjectConverter>
            <shuxdcs:FightPropertyToLocalizedStringConverter x:Key="FightPropertyToLocalizedStringConverter"/>
            <shuxdcs:FightPropertyToIconConverter x:Key="FightPropertyToIconConverter"/>

        <!--  网格视图技能模板  -->
        <DataTemplate x:Key="AvatarGridViewSkillTemplate" x:DataType="shvap:SkillView">
            <shuxcc:VerticalCard>
                <shuxcc:VerticalCard.Top>
                    <shuxci:CachedImage
                        Width="40"
                        Height="40"
                        Margin="12"
                        HorizontalAlignment="Center"
                        ShowAsMonoChrome="True"
                        Source="{Binding Icon}"/>
                </shuxcc:VerticalCard.Top>
                <shuxcc:VerticalCard.Bottom>
                    <Viewbox MaxWidth="52" StretchDirection="DownOnly">
                        <TextBlock Text="{Binding LevelFormatted}"/>
                    </Viewbox>
                </shuxcc:VerticalCard.Bottom>
            </shuxcc:VerticalCard>
        </DataTemplate>

        <!--  网格视图主模板  -->
        <DataTemplate x:Key="AvatarGridViewTemplate" x:DataType="shvap:CharacterView">
            <Grid Style="{ThemeResource GridShimmerStyle}">
                <Border
                    Grid.ColumnSpan="3"
                    Margin="-6"
                    CornerRadius="{ThemeResource ControlCornerRadius}">
                    <shuxci:CachedImage
                        MaxWidth="368"
                        MaxHeight="101"
                        VerticalAlignment="Center"
                        Opacity="0.5"
                        Source="{Binding NameCard}"
                        Stretch="UniformToFill"/>
                </Border>
                <Border Margin="-6" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"/>
                <Grid
                    Padding="6"
                    HorizontalAlignment="Left"
                    BackgroundSizing="OuterBorderEdge"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <shuxcc:VerticalCard Grid.Column="0">
                        <shuxcc:VerticalCard.Top>
                            <Grid cw:UIElementExtensions.ClipToBounds="True" CornerRadius="{ThemeResource ControlCornerRadius}">
                                <shuxc:ItemIcon
                                    Width="64"
                                    Height="64"
                                    Icon="{Binding Icon}"
                                    Quality="{Binding Rarity}"/>
                                <Border
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    Background="#80000000">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                        <Image
                                            Width="16"
                                            Height="16"
                                            Margin="2,0,0,2"
                                            VerticalAlignment="Center"
                                            Source="ms-appx:///Resource/Icon/UI_Icon_Fetter.png"/>
                                        <TextBlock
                                            Margin="0,0,6,2"
                                            VerticalAlignment="Center"
                                            Foreground="#FFFFFFFF"
                                            Text="{Binding FetterLevel}"/>
                                    </StackPanel>
                                </Border>
                                <Border
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="#80000000"
                                    CornerRadius="0,0,0,6">
                                    <TextBlock
                                        Margin="6,0,6,2"
                                        Foreground="#FFFFFFFF"
                                        Text="{Binding ActivatedConstellationCount}"/>
                                </Border>
                            </Grid>
                        </shuxcc:VerticalCard.Top>
                        <shuxcc:VerticalCard.Bottom>
                            <TextBlock Text="{Binding LevelFormatted}"/>
                        </shuxcc:VerticalCard.Bottom>
                    </shuxcc:VerticalCard>
                    <shuxcc:VerticalCard Grid.Column="1">
                        <shuxcc:VerticalCard.Top>
                            <Grid cw:UIElementExtensions.ClipToBounds="True" CornerRadius="{ThemeResource ControlCornerRadius}">
                                <shuxc:ItemIcon
                                    Width="64"
                                    Height="64"
                                    Icon="{Binding WeaponIcon}"
                                    Quality="{Binding WeaponRarity}"/>
                                <Border
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="#80000000"
                                    CornerRadius="0,0,0,6">
                                    <TextBlock
                                        Margin="6,0,6,2"
                                        Foreground="#FFFFFFFF"
                                        Text="{Binding WeaponAffixLevelNumber}"/>
                                </Border>
                            </Grid>
                        </shuxcc:VerticalCard.Top>
                        <shuxcc:VerticalCard.Bottom>
                            <TextBlock Text="{Binding WeaponLevel}"/>
                        </shuxcc:VerticalCard.Bottom>
                    </shuxcc:VerticalCard>
                    <ItemsControl
                        Grid.Column="2"
                        VerticalAlignment="Stretch"
                        ItemTemplate="{StaticResource AvatarGridViewSkillTemplate}"
                        ItemsPanel="{StaticResource HorizontalStackPanelSpacing6Template}"
                        ItemsSource="{Binding Skills}"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <!--  搜索标签模板  -->
        <DataTemplate x:Key="TokenTemplate" x:DataType="shuxca:SearchToken">
            <Grid Height="22" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Ellipse
                    Grid.Column="0"
                    Width="12"
                    Height="12"
                    Margin="1,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Visibility="{Binding Quality, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding Quality}"/>
                    </Ellipse.Fill>
                </Ellipse>
                <shuxci:CachedImage
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    Margin="-3,2,7,0"
                    ShowAsMonoChrome="True"
                    Source="{Binding IconUri, Mode=OneWay}"
                    Visibility="{Binding IconUri, Converter={StaticResource EmptyObjectToVisibilityConverter}}"/>
                <TextBlock
                    Grid.Column="1"
                    Height="20"
                    VerticalAlignment="Center"
                    Text="{Binding Value}"/>
            </Grid>
        </DataTemplate>

        <!--  突破星标模板  -->
        <DataTemplate x:Key="PromoteArrayTemplate" x:DataType="x:Boolean">
            <Grid>
                <BitmapIcon
                    Width="12"
                    Foreground="#FFFFFFFF"
                    UriSource="ms-appx:///Resource/Icon/UI_IconKira.png"
                    Visibility="{Binding}"/>
                <BitmapIcon
                    Width="12"
                    Foreground="#FF808080"
                    UriSource="ms-appx:///Resource/Icon/UI_IconKira.png"
                    Visibility="{Binding Converter={StaticResource BoolToVisibilityRevertConverter}}"/>
            </Grid>
        </DataTemplate>

        <!--  左侧角色列表模板  -->
        <DataTemplate x:Key="AvatarListViewTemplate" x:DataType="shvap:CharacterView">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <shuxci:CachedImage
                    Grid.Column="0"
                    Width="48"
                    Height="48"
                    Margin="0,0,12,12"
                    Source="{Binding Icon, Mode=OneWay}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        Margin="12,0,0,0"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"/>
                    <TextBlock
                        Margin="12,0,0,0"
                        Opacity="0.7"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding LevelFormatted}"
                        TextWrapping="NoWrap"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!--  命之座模板  -->
        <DataTemplate x:Key="AvatarConstellationTemplate" x:DataType="shwga:Constellation">
            <Button
                Margin="0,0,2,0"
                Padding="2"
                Background="Transparent"
                BorderBrush="{x:Null}">
                <Button.Content>
                    <Grid>
                        <shuxci:CachedImage
                            Width="36"
                            Height="36"
                            Opacity="{Binding IsActived, Converter={StaticResource BoolToOpacityConverter}}"
                            Source="{Binding Icon}"/>
                        <Image
                            Width="16"
                            Height="16"
                            Source="ms-appx:///Resource/Icon/UI_Icon_Locked.png"
                            Visibility="{Binding IsActived, Converter={StaticResource BoolToVisibilityRevertConverter}}"/>
                    </Grid>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <shuxct:DescriptionTextBlock
                            MaxWidth="320"
                            Description="{Binding Effect}"
                            TextStyle="{StaticResource BodyTextBlockStyle}"/>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </DataTemplate>

        <!--  天赋技能模板  -->
        <DataTemplate x:Key="AvatarSkillTemplate" x:DataType="shvap:SkillView">
            <Button
                Margin="0,2,0,0"
                Padding="4"
                Background="Transparent"
                BorderBrush="{x:Null}">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <shuxci:CachedImage
                            Grid.Column="0"
                            Width="36"
                            Height="36"
                            Source="{Binding Icon}"/>
                        <TextBlock
                            Grid.Column="1"
                            Margin="6,0,0,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="#FFFFFFFF"
                            Style="{StaticResource BaseTextBlockStyle}"
                            Text="{Binding LevelFormatted}"/>
                    </Grid>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="Left">
                        <StackPanel MaxWidth="320">
                            <StackPanel.Resources>
                                <!--  ReSharper disable Xaml.RedundantResource  -->
                                <Thickness x:Key="SettingsCardPadding">16</Thickness>
                                <x:Double x:Key="SettingsCardWrapThreshold">0</x:Double>
                                <x:Double x:Key="SettingsCardWrapNoIconThreshold">0</x:Double>
                                <x:Double x:Key="SettingsCardMinHeight">0</x:Double>
                                <!--  ReSharper restore Xaml.RedundantResource  -->
                            </StackPanel.Resources>
                            <shuxct:DescriptionTextBlock Description="{Binding Description}" TextStyle="{StaticResource BodyTextBlockStyle}"/>
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Info.Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="shmm:ParameterDescription">
                                        <cwcont:SettingsCard
                                            Margin="0,2,0,0"
                                            Padding="12,0"
                                            Header="{Binding Description}">
                                            <TextBlock Margin="0,8" Text="{Binding Parameter}"/>
                                        </cwcont:SettingsCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </DataTemplate>

        <!--  角色属性模板  -->
        <DataTemplate x:Key="AvatarPropertyTemplate" x:DataType="shwga:BaseProperty">
            <Grid
                Margin="-1,0"
                Padding="16,12"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="108"/>
                </Grid.ColumnDefinitions>
                <shuxci:CachedImage
                    Width="16"
                    Height="16"
                    ShowAsMonoChrome="True"
                    Source="{Binding PropertyType, Converter={StaticResource FightPropertyToIconConverter}}"/>
                <TextBlock
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    HorizontalAlignment="Left"
                    Text="{Binding PropertyType, Converter={StaticResource FightPropertyToLocalizedStringConverter}}"/>
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Text="{Binding Final}"/>
                <TextBlock
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    HorizontalAlignment="Left"
                    Foreground="{StaticResource AvatarPropertyAddValueColorBrush}"
                    Text="{Binding Add}"/>
            </Grid>
        </DataTemplate>

        <!--  圣遗物副词条模板  -->
        <DataTemplate x:Key="AvatarReliquarySubPropertyTemplate" x:DataType="shwga:ReliquaryProperty">
            <Grid Padding="12,0" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Style="{StaticResource BaseTextBlockStyle}"
                    Text="{Binding PropertyType, Converter={StaticResource FightPropertyToLocalizedStringConverter}}"
                    TextWrapping="NoWrap"/>
                <TextBlock Grid.Column="1" Text="{Binding Value}"/>
                <Grid Grid.Column="2" Opacity="1">
                    <Ellipse
                        Width="16"
                        Height="16"
                        Opacity="0.8"
                        StrokeThickness="1">
                        <Ellipse.Stroke>
                            <SolidColorBrush Color="{Binding Times, Converter={ThemeResource CountToGradientColorConverter}}"/>
                        </Ellipse.Stroke>
                    </Ellipse>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="{ThemeResource InfoBadgeValueFontSize}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding Times}">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding Times, Converter={ThemeResource CountToGradientColorConverter}}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>
            </Grid>
        </DataTemplate>

        <!--  圣遗物模板  -->
        <DataTemplate x:Key="AvatarReliquaryTemplate" x:DataType="shwga:Reliquary">
            <Grid Style="{ThemeResource GridShimmerStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid
                    Grid.Row="0"
                    Padding="12"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <shuxc:ItemIcon
                        Grid.Column="0"
                        Width="48"
                        Height="48"
                        Icon="{Binding Icon}"
                        Quality="{Binding Rarity}"/>
                    <Grid Grid.Column="1">
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock>
                                <Run Text="{Binding Name}"/>
                                <Run FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" +"/>
                                <Run FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Level}"/>
                            </TextBlock>
                            <TextBlock
                                Opacity="0.7"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding ReliquarySet.Name}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Rectangle
                    Grid.Row="1"
                    Height="1"
                    Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <!--  主词条  -->
                <Grid Grid.Row="2" Padding="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        FontWeight="Bold"
                        Style="{StaticResource BaseTextBlockStyle}"
                        Text="{Binding MainProperty.PropertyType, Converter={StaticResource FightPropertyToLocalizedStringConverter}}"/>
                    <TextBlock
                        Grid.Column="1"
                        FontWeight="Bold"
                        Style="{StaticResource BaseTextBlockStyle}"
                        Text="{Binding MainProperty.Value}"/>
                </Grid>
                <Rectangle
                    Grid.Row="3"
                    Height="1"
                    Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                <ItemsControl
                    Grid.Row="4"
                    Margin="0,12"
                    ItemTemplate="{StaticResource AvatarReliquarySubPropertyTemplate}"
                    ItemsPanel="{ThemeResource StackPanelSpacing12Template}"
                    ItemsSource="{Binding SubPropertyList}"/>
            </Grid>
        </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Border Background="#40000000"/>
        <!--  未登录状态  -->
        <Border
            x:Name="NotLoggedInPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
            Visibility="Collapsed">
            <Border
                MinWidth="480"
                Padding="16"
                Style="{ThemeResource AcrylicBorderCardStyle}">
                <StackPanel>
                    <shuxci:CachedImage
                        Width="120"
                        Height="120"
                        Source="{StaticResource UI_EmotionIcon250}"/>
                    <TextBlock
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{shuxm:ResourceString Name=ViewCommonLoginRequiredHint}"/>
                    <StackPanel Margin="0,24,0,0" Spacing="{StaticResource SettingsCardSpacing}">
                        <cwcont:SettingsCard
                            x:Name="LoginByQRCodeCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginQRCodeDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginQRCodeHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xED14;}"
                            IsClickEnabled="True"/>
                        <cwcont:SettingsCard
                            x:Name="LoginByMobileCaptchaCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginMobileCaptchaHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE8EA;}"
                            IsClickEnabled="True"/>
                        <cwcont:SettingsCard
                            x:Name="ManualInputCard"
                            Description="{shuxm:ResourceString Name=ViewCommonLoginManualInputDescription}"
                            Header="{shuxm:ResourceString Name=ViewCommonLoginManualInputHeader}"
                            HeaderIcon="{shuxm:FontIcon Glyph=&#xE109;}"
                            IsClickEnabled="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!--  已登录状态  -->
        <Grid x:Name="LoggedInPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!--  顶部命令栏  -->
            <Border Margin="16,16,16,0" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Style="{ThemeResource AcrylicSecondaryBorderCardStyle}">
                    <CommandBar
                        Grid.Row="0"
                        BorderBrush="{x:Null}"
                        BorderThickness="0"
                        DefaultLabelPosition="Right">
                        <CommandBar.Content>
                            <StackPanel Orientation="Horizontal">
                                <shuxc:LayoutSwitch
                                    x:Name="ItemsPanelSelector"
                                    Margin="4,8,0,0"
                                    LocalSettingKeySuffixForCurrent="AvatarPropertyPage.Characters"/>
                                <shuxc:SizeRestrictedContentControl Margin="8,8,0,0">
                                    <ComboBox
                                        Height="32"
                                        Padding="12,6,0,7"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{Binding SortDescriptionKinds}"
                                        SelectedItem="{Binding SortDescriptionKind, Mode=TwoWay}"
                                        Style="{ThemeResource DefaultComboBoxStyle}"/>
                                </shuxc:SizeRestrictedContentControl>
                            </StackPanel>
                        </CommandBar.Content>
                        <AppBarElementContainer>
                            <shuxca:AutoSuggestTokenBox
                                Width="600"
                                Height="44"
                                Margin="6,-2,6,6"
                                HorizontalAlignment="Right"
                                VerticalContentAlignment="Center"
                                AvailableTokens="{Binding SearchData.AvailableTokens}"
                                FilterCommand="{Binding FilterCommand}"
                                ItemsSource="{Binding SearchData.FilterTokens, Mode=TwoWay}"
                                MaximumTokens="5"
                                PlaceholderText="{shuxm:ResourceString Name=ViewPageWiKiAvatarAutoSuggestBoxPlaceHolder}"
                                QueryIcon="{cw:FontIconSource Glyph=&#xE721;}"
                                Style="{StaticResource DefaultAutoSuggestTokenBoxStyle}"
                                SuggestedItemTemplate="{StaticResource TokenTemplate}"
                                SuggestedItemsSource="{Binding SearchData.AvailableTokens.Values}"
                                Text="{Binding SearchData.FilterToken, Mode=TwoWay}"
                                TokenItemTemplate="{StaticResource TokenTemplate}"/>
                        </AppBarElementContainer>
                        <AppBarButton
                            Command="{Binding RefreshCommand}"
                            Icon="{shuxm:FontIcon Glyph=&#xE72C;}"
                            Label="{shuxm:ResourceString Name=ViewPageAvatarPropertyRefreshLabel}"/>
                    </CommandBar>
                </Border>
            </Border>

            <!--  SwitchPresenter：网格/列表视图切换  -->
            <Border Grid.Row="1" Margin="16,16,16,16" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                    <cwcont:SwitchPresenter ContentTransitions="{ThemeResource EntranceThemeTransitions}" Value="{Binding ElementName=ItemsPanelSelector, Path=Current, Mode=OneWay}">
                        <cwcont:Case Value="Grid">
                            <GridView
                                Margin="16,16,4,-4"
                                ItemContainerStyle="{StaticResource LargeGridViewItemStyle}"
                                ItemTemplate="{StaticResource AvatarGridViewTemplate}"
                                ItemsSource="{Binding Characters}"
                                SelectedItem="{Binding Characters.CurrentItem, Mode=TwoWay}"/>
                        </cwcont:Case>
                        <cwcont:Case Value="List">
                            <SplitView
                                DisplayMode="Inline"
                                IsPaneOpen="True"
                                OpenPaneLength="{StaticResource CompatSplitViewOpenPaneLength}"
                                PaneBackground="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <SplitView.Pane>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ListView
                                            Grid.Row="0"
                                            Padding="{ThemeResource ListViewInSplitPanePadding}"
                                            ItemTemplate="{StaticResource AvatarListViewTemplate}"
                                            ItemsSource="{Binding Characters}"
                                            SelectedItem="{Binding Characters.CurrentItem, Mode=TwoWay}"
                                            SelectionMode="Single"/>
                                        <Border
                                            Grid.Row="1"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="0,1,0,0">
                                            <TextBlock
                                                Margin="0,6"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{Binding FormattedTotalAvatarCount}"/>
                                        </Border>
                                    </Grid>
                                </SplitView.Pane>
                                <SplitView.Content>
                            <Grid x:Name="DetailContentRoot">
                                <StackPanel
                                    MaxWidth="800"
                                    Margin="16"
                                    HorizontalAlignment="Left"
                                    Spacing="16"
                                    Visibility="{Binding IsLoadingDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                        <Grid Style="{ThemeResource AcrylicGridCardStyle}">
                                            <cwcont:ConstrainedBox
                                                MinWidth="592"
                                                MinHeight="282"
                                                AspectRatio="840:400"
                                                CornerRadius="{ThemeResource ControlCornerRadius}">
                                                <clw:Shimmer/>
                                            </cwcont:ConstrainedBox>
                                        </Grid>
                                    </Border>
                                    <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                        <Grid Padding="16" Style="{ThemeResource AcrylicGridCardStyle}">
                                            <StackPanel Spacing="12">
                                                <clw:Shimmer
                                                    Width="220"
                                                    Height="16"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="8"/>
                                                <clw:Shimmer Height="12" CornerRadius="6"/>
                                                <clw:Shimmer Height="12" CornerRadius="6"/>
                                                <clw:Shimmer
                                                    Width="360"
                                                    Height="12"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                        <Grid Padding="16" Style="{ThemeResource AcrylicGridCardStyle}">
                                            <StackPanel Spacing="12">
                                                <clw:Shimmer
                                                    Width="180"
                                                    Height="16"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="8"/>
                                                <clw:Shimmer Height="12" CornerRadius="6"/>
                                                <clw:Shimmer
                                                    Width="420"
                                                    Height="12"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!--  详情滚动区域  -->
                                <ScrollViewer DataContext="{Binding CharacterDetail}" Visibility="{Binding ElementName=DetailContentRoot, Path=DataContext.IsLoadingDetail, Converter={StaticResource BoolToVisibilityRevertConverter}}">
                                    <StackPanel
                                        MaxWidth="800"
                                        Margin="16"
                                        HorizontalAlignment="Left"
                                        Spacing="16">

                                        <!--  名片横幅卡  -->
                                        <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                            <Grid Style="{ThemeResource AcrylicGridCardStyle}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <cwcont:ConstrainedBox
                                                    Grid.RowSpan="2"
                                                    Grid.ColumnSpan="2"
                                                    MinWidth="592"
                                                    MinHeight="282"
                                                    HorizontalAlignment="Center"
                                                    AspectRatio="840:400"
                                                    CornerRadius="{ThemeResource ControlCornerRadius}">
                                                    <shuxci:CachedImage
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Source="{Binding NameCard}"
                                                        Stretch="UniformToFill"/>
                                                </cwcont:ConstrainedBox>

                                                <Border
                                                    Grid.Row="0"
                                                    Grid.RowSpan="2"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Background="#80000000"
                                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                                    IsHitTestVisible="False"/>

                                                <!--  角色 + 武器信息  -->
                                                <StackPanel
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="16"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top">
                                                    <Grid HorizontalAlignment="Left">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <shuxc:ItemIcon
                                                            cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
                                                            Icon="{Binding Icon}"
                                                            Quality="{Binding Rarity}"/>
                                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                            <TextBlock
                                                                Foreground="#FFFFFFFF"
                                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                                Text="{Binding Name}"/>
                                                            <ItemsControl
                                                                Margin="0,2,0,0"
                                                                ItemTemplate="{StaticResource PromoteArrayTemplate}"
                                                                ItemsPanel="{ThemeResource HorizontalStackPanelSpacing2Template}"
                                                                ItemsSource="{Binding PromoteArray}"/>
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                Foreground="#FFFFFFFF"
                                                                Style="{StaticResource BaseTextBlockStyle}"
                                                                Text="{Binding LevelFormatted}"/>
                                                            <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                                                <Image
                                                                    Width="16"
                                                                    Height="16"
                                                                    Source="ms-appx:///Resource/Icon/UI_Icon_Fetter.png"/>
                                                                <TextBlock
                                                                    Margin="4,0,0,2"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#FFFFFFFF"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Text="{Binding Fetter}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                    <!--  武器  -->
                                                    <Grid Margin="0,16,0,0" HorizontalAlignment="Left">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button
                                                            Padding="0"
                                                            cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
                                                            BorderBrush="{x:Null}"
                                                            BorderThickness="0">
                                                            <Button.Content>
                                                                <shuxc:ItemIcon
                                                                    Icon="{Binding WeaponIcon}"
                                                                    Quality="{Binding WeaponRarity}"/>
                                                            </Button.Content>
                                                            <Button.Flyout>
                                                                <Flyout Placement="BottomEdgeAlignedLeft">
                                                                    <StackPanel>
                                                                        <StackPanel.Resources>
                                                                            <!--  ReSharper disable Xaml.RedundantResource  -->
                                                                            <x:Double x:Key="SettingsCardSpacing">3</x:Double>
                                                                            <x:Double x:Key="SettingsCardMinHeight">0</x:Double>
                                                                            <x:Double x:Key="SettingsCardWrapThreshold">0</x:Double>
                                                                            <x:Double x:Key="SettingsCardWrapNoIconThreshold">0</x:Double>
                                                                            <!--  ReSharper restore Xaml.RedundantResource  -->
                                                                        </StackPanel.Resources>
                                                                        <cwcont:SettingsCard
                                                                            Margin="0,2,0,0"
                                                                            Padding="12"
                                                                            Header="{Binding WeaponMainProperty.Name}">
                                                                            <TextBlock Text="{Binding WeaponMainProperty.Value}"/>
                                                                        </cwcont:SettingsCard>
                                                                        <cwcont:SettingsCard
                                                                            Margin="0,2,0,0"
                                                                            Padding="12"
                                                                            Header="{Binding WeaponSubProperty.Name}">
                                                                            <TextBlock Text="{Binding WeaponSubProperty.Value}"/>
                                                                        </cwcont:SettingsCard>
                                                                        <shuxct:DescriptionTextBlock
                                                                            MaxWidth="320"
                                                                            Margin="0,12,0,0"
                                                                            Description="{Binding WeaponAffixDescription}"/>
                                                                    </StackPanel>
                                                                </Flyout>
                                                            </Button.Flyout>
                                                        </Button>
                                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                            <TextBlock
                                                                Foreground="#FFFFFFFF"
                                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                                Text="{Binding WeaponName}"/>
                                                            <ItemsControl
                                                                Margin="0,2,0,0"
                                                                ItemTemplate="{StaticResource PromoteArrayTemplate}"
                                                                ItemsPanel="{ThemeResource HorizontalStackPanelSpacing2Template}"
                                                                ItemsSource="{Binding WeaponPromoteArray}"/>
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                Foreground="#FFFFFFFF"
                                                                Style="{StaticResource BaseTextBlockStyle}"
                                                                Text="{Binding WeaponLevelFormatted}"/>
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                Foreground="#FFFFFFFF"
                                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                                Text="{Binding WeaponAffixFormatted}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>

                                                <!--  天赋技能（右侧）  -->
                                                <ItemsControl
                                                    Grid.Row="0"
                                                    Grid.RowSpan="2"
                                                    Grid.Column="1"
                                                    Margin="16"
                                                    VerticalAlignment="Bottom"
                                                    ItemTemplate="{StaticResource AvatarSkillTemplate}"
                                                    ItemsSource="{Binding Skills}"/>

                                                <!--  命之座（底部）  -->
                                                <ItemsControl
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="16"
                                                    ItemTemplate="{StaticResource AvatarConstellationTemplate}"
                                                    ItemsPanel="{StaticResource HorizontalStackPanelSpacing0Template}"
                                                    ItemsSource="{Binding Constellations}"/>
                                            </Grid>
                                        </Border>

                                        <!--  角色属性折叠面板  -->
                                        <Border>
                                            <Border.Resources>
                                                <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent"/>
                                                <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="{ThemeResource ControlStrokeColorDefault}"/>
                                                <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="{ThemeResource ControlStrokeColorDefault}"/>
                                                <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="{ThemeResource ControlAltFillColorSecondary}"/>
                                                <SolidColorBrush x:Key="ExpanderHeaderBorderPointerOverBrush" Color="{ThemeResource ControlStrokeColorDefault}"/>
                                            </Border.Resources>
                                            <Expander
                                                Margin="0"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Header="{shuxm:ResourceString Name=ViewPageAvatarPropertyPropertiesHeader}">
                                                <Border
                                                    Margin="0,-1,0,0"
                                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                                    BorderThickness="0">
                                                    <ItemsControl ItemTemplate="{StaticResource AvatarPropertyTemplate}" ItemsSource="{Binding Properties}"/>
                                                </Border>
                                            </Expander>
                                        </Border>

                                        <!--  推荐属性  -->
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>

                                            <shuxcc:VerticalCard Grid.Column="0" HorizontalBottomAlignment="Left">
                                                <shuxcc:VerticalCard.Top>
                                                    <TextBlock
                                                        Margin="12"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Text="{shuxm:ResourceString Name=UIViewPageAvatarPropertyRecommendedSandProperties}"/>
                                                </shuxcc:VerticalCard.Top>
                                                <shuxcc:VerticalCard.Bottom>
                                                    <ItemsControl
                                                        Margin="12"
                                                        VerticalAlignment="Center"
                                                        ItemsPanel="{StaticResource WrapPanelSpacing4Template}"
                                                        ItemsSource="{Binding RecommendedSandProperties}"/>
                                                </shuxcc:VerticalCard.Bottom>
                                            </shuxcc:VerticalCard>
                                            <Image
                                                Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Source="ms-appx:///Resource/Icon/UI_Icon_RelicType3.png"/>

                                            <shuxcc:VerticalCard Grid.Column="1" HorizontalBottomAlignment="Left">
                                                <shuxcc:VerticalCard.Top>
                                                    <TextBlock
                                                        Margin="12"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Text="{shuxm:ResourceString Name=UIViewPageAvatarPropertyRecommendedGobletProperties}"/>
                                                </shuxcc:VerticalCard.Top>
                                                <shuxcc:VerticalCard.Bottom>
                                                    <ItemsControl
                                                        Margin="12"
                                                        VerticalAlignment="Center"
                                                        ItemsPanel="{StaticResource WrapPanelSpacing4Template}"
                                                        ItemsSource="{Binding RecommendedGobletProperties}"/>
                                                </shuxcc:VerticalCard.Bottom>
                                            </shuxcc:VerticalCard>
                                            <Image
                                                Grid.Column="1"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Source="ms-appx:///Resource/Icon/UI_Icon_RelicType4.png"/>

                                            <shuxcc:VerticalCard Grid.Column="2" HorizontalBottomAlignment="Left">
                                                <shuxcc:VerticalCard.Top>
                                                    <TextBlock
                                                        Margin="12"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Text="{shuxm:ResourceString Name=UIViewPageAvatarPropertyRecommendedCircletProperties}"/>
                                                </shuxcc:VerticalCard.Top>
                                                <shuxcc:VerticalCard.Bottom>
                                                    <ItemsControl
                                                        Margin="12"
                                                        VerticalAlignment="Center"
                                                        ItemsPanel="{StaticResource WrapPanelSpacing4Template}"
                                                        ItemsSource="{Binding RecommendedCircletProperties}"/>
                                                </shuxcc:VerticalCard.Bottom>
                                            </shuxcc:VerticalCard>
                                            <Image
                                                Grid.Column="2"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Source="ms-appx:///Resource/Icon/UI_Icon_RelicType5.png"/>

                                            <shuxcc:VerticalCard Grid.Column="3" HorizontalBottomAlignment="Left">
                                                <shuxcc:VerticalCard.Top>
                                                    <TextBlock
                                                        Margin="12"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Text="{shuxm:ResourceString Name=UIViewPageAvatarPropertyRecommendedAppendProperties}"/>
                                                </shuxcc:VerticalCard.Top>
                                                <shuxcc:VerticalCard.Bottom>
                                                    <ItemsControl
                                                        Margin="12"
                                                        VerticalAlignment="Center"
                                                        ItemsPanel="{StaticResource WrapPanelSpacing4Template}"
                                                        ItemsSource="{Binding RecommendedSubProperties}"/>
                                                </shuxcc:VerticalCard.Bottom>
                                            </shuxcc:VerticalCard>
                                        </Grid>

                                        <!--  圣遗物网格  -->
                                        <ItemsControl ItemTemplate="{StaticResource AvatarReliquaryTemplate}" ItemsSource="{Binding Relics}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <shuxcp:UniformPanel
                                                        ColumnSpacing="12"
                                                        MinItemWidth="240"
                                                        RowSpacing="12"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </SplitView.Content>
                    </SplitView>
                        </cwcont:Case>
                    </cwcont:SwitchPresenter>
                </Border>
            </Border>
        </Grid>
    </Grid>
</shuxc:ScopedPage>
