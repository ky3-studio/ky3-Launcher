<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.WikiFoodPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shmmf="using:kyxsan.Model.Metadata.Food"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxca="using:kyxsan.UI.Xaml.Control.AutoSuggestBox"
    xmlns:shuxcc="using:kyxsan.UI.Xaml.Control.Card"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxct="using:kyxsan.UI.Xaml.Control.TextBlock"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shvw="using:kyxsan.ViewModel.Wiki"
    d:DataContext="{d:DesignInstance Type=shvw:WikiFoodViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <DataTemplate x:Key="TokenTemplate" x:DataType="shuxca:SearchToken">
            <Grid Height="22" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <shuxci:CachedImage
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    Margin="-3,2,7,0"
                    Source="{Binding IconUri, Mode=OneWay}"
                    Visibility="{Binding IconUri, Converter={StaticResource EmptyObjectToVisibilityConverter}}"/>
                <TextBlock
                    Grid.Column="1"
                    Height="20"
                    VerticalAlignment="Center"
                    Text="{Binding Value}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FoodListTemplate" x:DataType="shmmf:Food">
            <Grid Height="48" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <shuxci:CachedImage
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    Source="{Binding Icon, Converter={StaticResource ItemIconConverter}, Mode=OneWay}"/>
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding Name}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FoodGridTemplate" x:DataType="shmmf:Food">
            <shuxcc:VerticalCard Width="82">
                <shuxcc:VerticalCard.Top>
                    <shuxc:ItemIcon Icon="{Binding Icon, Converter={StaticResource ItemIconConverter}, Mode=OneWay}" Quality="{Binding Quality}"/>
                </shuxcc:VerticalCard.Top>
                <shuxcc:VerticalCard.Bottom>
                    <TextBlock
                        Margin="2,0"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis"/>
                </shuxcc:VerticalCard.Bottom>
            </shuxcc:VerticalCard>
        </DataTemplate>

        <DataTemplate x:Key="FoodInventoryTemplate" x:DataType="shmmf:Food">
            <shuxcc:HorizontalCard Width="300">
                <shuxcc:HorizontalCard.Left>
                    <shuxc:ItemIcon
                        Width="40"
                        Height="40"
                        Icon="{Binding Icon, Converter={StaticResource ItemIconConverter}}"
                        Quality="{Binding Quality}"/>
                </shuxcc:HorizontalCard.Left>
                <shuxcc:HorizontalCard.Right>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis"/>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{Binding InventoryCount}"/>
                    </Grid>
                </shuxcc:HorizontalCard.Right>
            </shuxcc:HorizontalCard>
        </DataTemplate>

        <DataTemplate x:Key="RecipeInputTemplate" x:DataType="shmmf:FoodRecipeInput">
            <shuxcc:HorizontalCard>
                <shuxcc:HorizontalCard.Left>
                    <shuxc:ItemIcon
                        Width="40"
                        Height="40"
                        Icon="{Binding Icon, Converter={StaticResource ItemIconConverter}}"/>
                </shuxcc:HorizontalCard.Left>
                <shuxcc:HorizontalCard.Right>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock
                            Opacity="0.6"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding CountText}"/>
                    </StackPanel>
                </shuxcc:HorizontalCard.Right>
            </shuxcc:HorizontalCard>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Border Background="#40000000"/>
        <shuxc:StandardView ShowCondition="{Binding Foods, Converter={StaticResource EmptyObjectToBoolConverter}}">
            <shuxc:StandardView.EmptyContent>
                <shuxc:Loading IsLoading="{Binding Foods, Converter={StaticResource EmptyObjectToBoolRevertConverter}}" Style="{ThemeResource DefaultLoadingViewStyle}"/>
            </shuxc:StandardView.EmptyContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Margin="16,16,16,0" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <CommandBar
                            BorderBrush="{x:Null}"
                            BorderThickness="0"
                            DefaultLabelPosition="Right">
                            <CommandBar.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <shuxc:LayoutSwitch
                                        x:Name="LayoutSelector"
                                        Margin="8,8,0,0"
                                        LocalSettingKeySuffixForCurrent="WikiFoodPage.Foods"/>
                                    <!--<ToggleButton
                                        x:Name="InventoryToggle"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon VerticalAlignment="Center" FontSize="14" Glyph="&#xE8B7;"/>
                                            <TextBlock VerticalAlignment="Center" Text="{shuxm:ResourceString Name=ViewWikiFoodInventoryHeader}"/>
                                        </StackPanel>
                                    </ToggleButton>-->
                                </StackPanel>
                            </CommandBar.Content>
                            <AppBarElementContainer>
                                <shuxca:AutoSuggestTokenBox
                                    Width="600"
                                    Height="44"
                                    Margin="6,-2,6,6"
                                    HorizontalAlignment="Right"
                                    VerticalContentAlignment="Center"
                                    AvailableTokens="{Binding SearchData.AvailableTokens}"
                                    FilterCommand="{Binding FilterCommand}"
                                    ItemsSource="{Binding SearchData.FilterTokens, Mode=TwoWay}"
                                    MaximumTokens="5"
                                    PlaceholderText="{shuxm:ResourceString Name=ViewWikiFoodSearchPlaceholder}"
                                    QueryIcon="{cw:FontIconSource Glyph=&#xE721;}"
                                    Style="{StaticResource DefaultAutoSuggestTokenBoxStyle}"
                                    SuggestedItemTemplate="{StaticResource TokenTemplate}"
                                    SuggestedItemsSource="{Binding SearchData.AvailableTokens.Values}"
                                    Text="{Binding SearchData.FilterToken, Mode=TwoWay}"
                                    TokenItemTemplate="{StaticResource TokenTemplate}"/>
                            </AppBarElementContainer>
                        </CommandBar>
                    </Border>
                </Border>
                <cwc:SwitchPresenter
                    Grid.Row="1"
                    ContentTransitions="{ThemeResource EntranceThemeTransitions}"
                    Value="{Binding ElementName=LayoutSelector, Path=Current}"
                    Visibility="Visible">
                        <cwc:Case Value="List">
                            <Border Margin="16" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                                    <SplitView
                                        DisplayMode="Inline"
                                        IsPaneOpen="True"
                                        OpenPaneLength="{StaticResource CompatSplitViewOpenPaneLength}"
                                        PaneBackground="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <SplitView.Pane>
                                        <ListView
                                            Padding="{ThemeResource ListViewInSplitPanePadding}"
                                            ItemTemplate="{StaticResource FoodListTemplate}"
                                            ItemsSource="{Binding Foods}"
                                            SelectedItem="{Binding Foods.CurrentItem, Mode=TwoWay}"
                                            SelectionMode="Single">
                                            <mxi:Interaction.Behaviors>
                                                <shuxb:SelectedItemInViewBehavior/>
                                            </mxi:Interaction.Behaviors>
                                        </ListView>
                                    </SplitView.Pane>
                                    <SplitView.Content>
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" Visibility="{Binding Foods.CurrentItem, Converter={StaticResource EmptyObjectToVisibilityRevertConverter}}">
                                                <shuxci:CachedImage
                                                    Height="120"
                                                    MinWidth="{ThemeResource SettingsCardContentControlMinWidth}"
                                                    Source="{StaticResource UI_EmotionIcon89}"/>
                                                <TextBlock
                                                    Margin="0,5,0,21"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                                    Text="{shuxm:ResourceString Name=ControlAutoSuggestBoxNotFoundValue}"/>
                                            </StackPanel>
                                            <ScrollViewer
                                                Padding="16,0"
                                                shuxc:ScrollViewerHelper.ScrollToTopAssociatedObject="{Binding Foods.CurrentItem}"
                                                Visibility="{Binding Foods.CurrentItem, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                                <StackPanel Margin="0,16" Spacing="16">
                                                    <Border Padding="16" Style="{ThemeResource BorderCardStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="auto"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <shuxc:ItemIcon
                                                                Width="96"
                                                                Height="96"
                                                                Icon="{Binding Foods.CurrentItem.Icon, Converter={StaticResource ItemIconConverter}}"
                                                                Quality="{Binding Foods.CurrentItem.Quality}"/>
                                                            <StackPanel
                                                                Grid.Column="1"
                                                                Margin="16,0,0,0"
                                                                VerticalAlignment="Center">
                                                                <TextBlock
                                                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                                                    Text="{Binding Foods.CurrentItem.Name}"/>
                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    Opacity="0.6"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Text="{Binding Foods.CurrentItem.SpecialDishLabel}"
                                                                    Visibility="{Binding Foods.CurrentItem.Character, Converter={StaticResource EmptyObjectToVisibilityConverter}}"/>
                                                                <TextBlock
                                                                    Margin="0,8,0,0"
                                                                    Opacity="0.8"
                                                                    Text="{Binding Foods.CurrentItem.Description}"
                                                                    TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <Border
                                                        Padding="16"
                                                        Style="{ThemeResource BorderShimmerStyle}"
                                                        Visibility="{Binding Foods.CurrentItem.Character, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                                        <StackPanel Spacing="12">
                                                            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewWikiFoodCategorySpecial}"/>
                                                            <StackPanel
                                                                HorizontalAlignment="Center"
                                                                Orientation="Horizontal"
                                                                Spacing="12">
                                                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                                                    <shuxc:ItemIcon
                                                                        Width="48"
                                                                        Height="48"
                                                                        Icon="{Binding Foods.CurrentItem.CharacterIconUri}"
                                                                        Quality="{Binding Foods.CurrentItem.CharacterQuality}"/>
                                                                    <TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                                        Text="{Binding Foods.CurrentItem.Character}"/>
                                                                </StackPanel>
                                                                <TextBlock
                                                                    VerticalAlignment="Center"
                                                                    FontSize="16"
                                                                    Opacity="0.5"
                                                                    Text="+"/>
                                                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                                                    <shuxc:ItemIcon
                                                                        Width="48"
                                                                        Height="48"
                                                                        Icon="{Binding Foods.CurrentItem.BaseDishIconUri}"
                                                                        Quality="{Binding Foods.CurrentItem.Quality}"/>
                                                                    <TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                                        Text="{Binding Foods.CurrentItem.BaseDishOrSkillLabel}"/>
                                                                </StackPanel>
                                                                <TextBlock
                                                                    VerticalAlignment="Center"
                                                                    FontSize="16"
                                                                    Opacity="0.5"
                                                                    Text="="/>
                                                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                                                    <shuxc:ItemIcon
                                                                        Width="48"
                                                                        Height="48"
                                                                        Icon="{Binding Foods.CurrentItem.Icon, Converter={StaticResource ItemIconConverter}}"
                                                                        Quality="{Binding Foods.CurrentItem.Quality}"/>
                                                                    <TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                                        Text="{Binding Foods.CurrentItem.Name}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border
                                                        Padding="16"
                                                        Style="{ThemeResource BorderShimmerStyle}"
                                                        Visibility="{Binding Foods.CurrentItem.Recipe, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                                        <StackPanel Spacing="12">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <shuxci:CachedImage
                                                                    Width="24"
                                                                    Height="24"
                                                                    Source="{Binding Foods.CurrentItem.EffectIcon, Converter={StaticResource BuffIconConverter}}"/>
                                                                <TextBlock
                                                                    VerticalAlignment="Center"
                                                                    Style="{StaticResource BaseTextBlockStyle}"
                                                                    Text="{shuxm:ResourceString Name=ViewWikiFoodEffectTitle}"/>
                                                            </StackPanel>
                                                            <shuxct:HtmlDescriptionTextBlock
                                                                Opacity="0.8"
                                                                Description="{Binding Foods.CurrentItem.EffectDescription}"
                                                                TextStyle="{StaticResource BodyTextBlockStyle}"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border
                                                        Padding="16"
                                                        Style="{ThemeResource BorderShimmerStyle}"
                                                        Visibility="{Binding Foods.CurrentItem.Recipe.Input.Length, Converter={StaticResource Int32ToVisibilityConverter}, FallbackValue=Collapsed}">
                                                        <StackPanel Spacing="12">
                                                            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewWikiFoodRecipeTitle}"/>
                                                            <ItemsControl ItemTemplate="{StaticResource RecipeInputTemplate}" ItemsSource="{Binding Foods.CurrentItem.Recipe.Input}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <cwc:UniformGrid
                                                                            ColumnSpacing="8"
                                                                            Columns="2"
                                                                            RowSpacing="8"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border
                                                        Padding="16"
                                                        Style="{ThemeResource BorderShimmerStyle}"
                                                        Visibility="{Binding Foods.CurrentItem.Cooking, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                                                        <StackPanel Spacing="12">
                                                            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{shuxm:ResourceString Name=ViewWikiFoodCookingTitle}"/>
                                                            <shuxci:CachedImage
                                                                Height="80"
                                                                Source="{Binding Foods.CurrentItem.Cooking.ImageName, Converter={StaticResource CookingGuideConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </SplitView.Content>
                                    </SplitView>
                                </Border>
                            </Border>
                        </cwc:Case>
                        <cwc:Case Value="Grid">
                            <Border Margin="16" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                                <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                                    <Grid Padding="16,16,4,-6">
                                        <StackPanel VerticalAlignment="Center" Visibility="{Binding Foods.Count, Converter={StaticResource Int32ToVisibilityRevertConverter}}">
                                            <shuxci:CachedImage
                                                Height="120"
                                                MinWidth="{ThemeResource SettingsCardContentControlMinWidth}"
                                                Source="{StaticResource UI_EmotionIcon89}"/>
                                            <TextBlock
                                                Margin="0,5,0,21"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                Text="{shuxm:ResourceString Name=ControlAutoSuggestBoxNotFoundValue}"/>
                                        </StackPanel>
                                        <GridView
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            ItemContainerStyle="{StaticResource LargeGridViewItemStyle}"
                                            ItemTemplate="{StaticResource FoodGridTemplate}"
                                            ItemsSource="{Binding Foods}"
                                            SelectedItem="{Binding Foods.CurrentItem, Mode=TwoWay}"
                                            SelectionMode="Single"
                                            Visibility="{Binding Foods.Count, Converter={StaticResource Int32ToVisibilityConverter}}">
                                            <mxi:Interaction.Behaviors>
                                                <shuxb:SelectedItemInViewBehavior/>
                                            </mxi:Interaction.Behaviors>
                                        </GridView>
                                    </Grid>
                                </Border>
                            </Border>
                        </cwc:Case>
                </cwc:SwitchPresenter>
                <Border
                    Grid.Row="1"
                    Margin="16,0,16,16"
                    cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
                    Visibility="Collapsed">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <GridView
                            Padding="16,16,10,10"
                            ItemTemplate="{StaticResource FoodInventoryTemplate}"
                            ItemsSource="{Binding InventoryFoods}"
                            SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,0,6,6"/>
                                </Style>
                            </GridView.ItemContainerStyle>
                        </GridView>
                    </Border>
                </Border>
            </Grid>
        </shuxc:StandardView>
    </Grid>
</shuxc:ScopedPage>
