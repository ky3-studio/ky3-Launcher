<shuxc:ScopedPage
    x:Class="kyxsan.UI.Xaml.View.Page.WishCountdownPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cw="using:CommunityToolkit.WinUI"
    xmlns:cwcont="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mxi="using:Microsoft.Xaml.Interactivity"
    xmlns:shuxb="using:kyxsan.UI.Xaml.Behavior"
    xmlns:shuxc="using:kyxsan.UI.Xaml.Control"
    xmlns:shuxci="using:kyxsan.UI.Xaml.Control.Image"
    xmlns:shuxm="using:kyxsan.UI.Xaml.Markup"
    xmlns:shvg="using:kyxsan.ViewModel.GachaLog"
    d:DataContext="{d:DesignInstance shvg:WishCountdownViewModel}"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <mxi:Interaction.Behaviors>
        <shuxb:InvokeCommandOnLoadedBehavior Command="{Binding LoadCommand}"/>
    </mxi:Interaction.Behaviors>

    <Page.Resources>
        <DataTemplate x:Key="CountdownListItemTemplate" x:DataType="shvg:Countdown">
            <Border Margin="0,4" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Grid Style="{StaticResource AcrylicGridCardStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border
                        cw:UIElementExtensions.ClipToBounds="True"
                        CornerRadius="{ThemeResource ControlCornerRadiusTop}"
                        DoubleTapped="OnBannerDoubleTapped">
                        <cwcont:ConstrainedBox AspectRatio="1080:533">
                            <shuxci:CachedImage
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Source="{Binding LatestBanner}"
                                Stretch="UniformToFill"/>
                        </cwcont:ConstrainedBox>
                    </Border>
                    <Grid
                        Grid.Row="1"
                        Padding="8"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <shuxc:ItemIcon
                            Width="40"
                            Height="40"
                            Icon="{Binding Item.Icon}"
                            Quality="{Binding Item.Quality}"/>
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                Text="{Binding Item.Name}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap"/>
                            <TextBlock
                                Opacity="0.7"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding FormattedCountdown}"
                                TextWrapping="NoWrap"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CountdownHistoryBannerTemplate" x:DataType="shvg:CountdownHistory">
            <Border Margin="0,4" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Grid Style="{StaticResource AcrylicGridCardStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border cw:UIElementExtensions.ClipToBounds="True" CornerRadius="{ThemeResource ControlCornerRadiusTop}">
                        <cwcont:ConstrainedBox AspectRatio="1080:533">
                            <shuxci:CachedImage
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Source="{Binding Banner}"
                                Stretch="UniformToFill"/>
                        </cwcont:ConstrainedBox>
                    </Border>
                    <StackPanel
                        Grid.Row="1"
                        Padding="12,8"
                        Spacing="2">
                        <TextBlock
                            Style="{StaticResource BaseTextBlockStyle}"
                            Text="{Binding FormattedVersionOrder}"/>
                        <TextBlock
                            Opacity="0.6"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding FormattedTime}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <shuxc:Loading
            CornerRadius="{ThemeResource ControlCornerRadius}"
            IsLoading="{Binding IsInitialized, Converter={StaticResource BoolNegationConverter}}"
            Style="{ThemeResource DefaultLoadingViewStyle}"/>
        <Border Background="#40000000"/>
        <Grid Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                <Border Padding="6" Style="{ThemeResource AcrylicBorderCardStyle}">
                    <AutoSuggestBox
                        Margin="6"
                        Height="36"
                        PlaceholderText="{shuxm:ResourceString Name=ViewPageGachaLogCountdownSearchPlaceholder}"
                        QueryIcon="{shuxm:FontIcon Glyph=&#xE721;}"
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="12,12,12,4"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewPageGachaLogOrangeAvatarCountdown}"/>
                            <ListView
                                Grid.Row="1"
                                Padding="{ThemeResource ListViewInSplitPanePadding}"
                                ItemTemplate="{StaticResource CountdownListItemTemplate}"
                                ItemsSource="{Binding FilteredOrangeAvatars}"/>
                        </Grid>
                    </Border>
                </Border>

                <Border Grid.Column="1" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="12,12,12,4"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewPageGachaLogPurpleAvatarCountdown}"/>
                            <ListView
                                Grid.Row="1"
                                Padding="{ThemeResource ListViewInSplitPanePadding}"
                                ItemTemplate="{StaticResource CountdownListItemTemplate}"
                                ItemsSource="{Binding FilteredPurpleAvatars}"/>
                        </Grid>
                    </Border>
                </Border>

                <Border Grid.Column="2" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="12,12,12,4"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewPageGachaLogOrangeWeaponCountdown}"/>
                            <ListView
                                Grid.Row="1"
                                Padding="{ThemeResource ListViewInSplitPanePadding}"
                                ItemTemplate="{StaticResource CountdownListItemTemplate}"
                                ItemsSource="{Binding FilteredOrangeWeapons}"/>
                        </Grid>
                    </Border>
                </Border>

                <Border Grid.Column="3" cw:Effects.Shadow="{ThemeResource CompatCardShadow}">
                    <Border Style="{ThemeResource AcrylicBorderCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="12,12,12,4"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{shuxm:ResourceString Name=ViewPageGachaLogPurpleWeaponCountdown}"/>
                            <ListView
                                Grid.Row="1"
                                Padding="{ThemeResource ListViewInSplitPanePadding}"
                                ItemTemplate="{StaticResource CountdownListItemTemplate}"
                                ItemsSource="{Binding FilteredPurpleWeapons}"/>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="ImagePreviewOverlay"
            Background="#CC000000"
            DoubleTapped="OnPreviewCloseDouble"
            Tapped="OnPreviewClose"
            Visibility="Collapsed">
            <Border
                Margin="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                cw:Effects.Shadow="{ThemeResource CompatCardShadow}"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <shuxci:CachedImage
                    x:Name="PreviewImage"
                    MaxWidth="1280"
                    Stretch="Uniform"/>
            </Border>
        </Grid>
    </Grid>
</shuxc:ScopedPage>
